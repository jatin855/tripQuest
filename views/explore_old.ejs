// ══════════════════════════════════════════════════
// APP STATE
// ══════════════════════════════════════════════════
let allCities      = [];
let currentState   = null;
let activeFilter   = 'All';
let searchQuery    = '';
let sortMode       = 'default';
let isGlobalSearch = false;
let globalResults  = [];

let exploreFilter    = 'All';
let exploreQuery     = '';
let exploreAllCities = [];

const stateDataCache = {};

// ══════════════════════════════════════════════════
// MAIN
// ══════════════════════════════════════════════════
async function main() {
  const params  = new URLSearchParams(window.location.search);
  const stateId = params.get('state') || STATE_REGISTRY[0].id;

  buildStateDropdown(stateId);
  buildStatesBrowser(stateId);
  buildFooterLinks();
  buildCatPills();
  initNav();
  initScrollFadeIn();

  await loadState(stateId);
  initHero();

  prefetchPopularStates();

  setTimeout(() => {
    document.getElementById('loader').classList.add('out');
    setTimeout(() => { const l = document.getElementById('loader'); if(l) l.remove(); }, 800);
  }, 2000);
}

async function prefetchPopularStates() {
  const popular = ['rajasthan','kerala','goa','himachal-pradesh','delhi','uttarakhand'];
  for (const id of popular) {
    if (!stateDataCache[id]) {
      const meta = STATE_REGISTRY.find(s => s.id === id);
      if (!meta) continue;
      try {
        const res = await fetch(meta.file);
        if (res.ok) { stateDataCache[id] = (await res.json()).cities; }
      } catch(e) {}
    }
  }
  rebuildExploreAll();
}

function rebuildExploreAll() {
  exploreAllCities = [];
  for (const [stateId, cities] of Object.entries(stateDataCache)) {
    const meta = STATE_REGISTRY.find(s => s.id === stateId);
    if (!meta) continue;
    cities.forEach(c => exploreAllCities.push({ ...c, _stateId: stateId, _stateMeta: meta }));
  }
  renderExploreSection();
}

// ══════════════════════════════════════════════════
// LOAD STATE
// ══════════════════════════════════════════════════
async function loadState(stateId) {
  const stateMeta = STATE_REGISTRY.find(s => s.id === stateId);
  if (!stateMeta) { console.error('State not found:', stateId); return; }

  currentState   = stateMeta;
  isGlobalSearch = false;

  const loaderSub = document.getElementById('loaderSub');
  if (loaderSub) loaderSub.textContent = `Loading ${stateMeta.name}`;

  if (stateDataCache[stateId]) {
    allCities = stateDataCache[stateId];
  } else {
    try {
      const res  = await fetch(stateMeta.file);
      if (!res.ok) throw new Error(`Could not load ${stateMeta.file}`);
      const data = await res.json();
      allCities  = data.cities;
      stateDataCache[stateId] = allCities;
    } catch (err) {
      document.getElementById('cityGrid').innerHTML = `
        <div class="no-results">
          <span class="no-results-icon">⚠️</span>
          <h3>Could not load data</h3>
          <p>Make sure <strong>${stateMeta.file}</strong> exists.</p>
        </div>`;
      return;
    }
  }

  activeFilter = 'All';
  sortMode     = 'default';
  document.getElementById('searchInput').value = '';
  document.getElementById('cbClearBtn').classList.remove('visible');
  searchQuery  = '';

  const url = new URL(window.location);
  url.searchParams.set('state', stateId);
  window.history.replaceState({}, '', url);

  updateHeroForState(stateMeta);
  updateStateHeader(stateMeta);
  buildFilters(allCities);
  showSingleStateMode();
  renderSingleState();

  document.querySelectorAll('.state-card').forEach(c => {
    c.classList.toggle('active-state', c.dataset.stateId === stateId);
  });
  document.getElementById('stateSelect').value = stateId;
  document.getElementById('globalSearchBanner').classList.remove('visible');

  rebuildExploreAll();
}

function switchState(stateId) { loadState(stateId); }

// ══════════════════════════════════════════════════
// RENDER MODES
// ══════════════════════════════════════════════════
function showSingleStateMode() {
  document.getElementById('singleStateSection').style.display = '';
  document.getElementById('statesCitySection').style.display  = 'none';
  document.getElementById('utsCitySection').style.display     = 'none';
  document.getElementById('stateHeaderCard').style.display    = 'flex';
}

function showGlobalSearchMode() {
  document.getElementById('singleStateSection').style.display = 'none';
  document.getElementById('statesCitySection').style.display  = '';
  document.getElementById('utsCitySection').style.display     = '';
  document.getElementById('stateHeaderCard').style.display    = 'none';
}

// ══════════════════════════════════════════════════
// SINGLE-STATE RENDER
// ══════════════════════════════════════════════════
function renderSingleState() {
  const filtered = getFilteredSingle();
  const grid     = document.getElementById('cityGrid');

  document.getElementById('resultsCount').textContent =
    `${filtered.length} destination${filtered.length !== 1 ? 's' : ''}`;

  if (!filtered.length) {
    grid.innerHTML = `<div class="no-results"><span class="no-results-icon">🗺</span><h3>No destinations found</h3><p>Try a different search or filter.</p></div>`;
    return;
  }

  const isUT = UT_IDS.has(currentState.id);
  grid.innerHTML = filtered.map((city, idx) => renderCityCard(city, idx, filtered.length, currentState, isUT)).join('');
}

function getFilteredSingle() {
  let cities = [...allCities];
  if (searchQuery) cities = cities.filter(c => matchesQuery(c, searchQuery));
  if (activeFilter !== 'All') cities = cities.filter(c => matchesCityFilter(c, activeFilter));
  return applySortMode(cities);
}

// ══════════════════════════════════════════════════
// GLOBAL SEARCH
// ══════════════════════════════════════════════════
async function performGlobalSearch(query) {
  globalResults = [];
  const statesHit = new Set();

  for (const [stateId, cities] of Object.entries(stateDataCache)) {
    const meta = STATE_REGISTRY.find(s => s.id === stateId);
    if (!meta) continue;
    const hits = cities.filter(c => matchesQuery(c, query));
    hits.forEach(c => {
      globalResults.push({ ...c, _stateId: stateId, _stateMeta: meta });
      statesHit.add(stateId);
    });
  }

  renderGlobalResults(query, statesHit.size);
}

function renderGlobalResults(query, stateCount) {
  showGlobalSearchMode();

  const banner = document.getElementById('globalSearchBanner');
  banner.classList.add('visible');
  document.getElementById('gsbStateCount').textContent = `${stateCount} loaded`;

  const stateResults = globalResults.filter(c => !UT_IDS.has(c._stateId));
  const utResults    = globalResults.filter(c =>  UT_IDS.has(c._stateId));

  document.getElementById('resultsCount').textContent =
    `${globalResults.length} result${globalResults.length !== 1 ? 's' : ''}`;

  const statesDivider = document.getElementById('statesDivider');
  const statesGrid    = document.getElementById('statesCityGrid');
  if (stateResults.length) {
    statesDivider.style.display = 'flex';
    document.getElementById('statesResultCount').textContent = `${stateResults.length} results`;
    statesGrid.innerHTML = stateResults.map((c, i) =>
      renderCityCard(c, i, stateResults.length, c._stateMeta, false, true)
    ).join('');
  } else {
    statesDivider.style.display = 'none';
    statesGrid.innerHTML = '';
  }

  const utsDivider = document.getElementById('utsDivider');
  const utsGrid    = document.getElementById('utsCityGrid');
  if (utResults.length) {
    utsDivider.style.display = 'flex';
    document.getElementById('utsResultCount').textContent = `${utResults.length} results`;
    utsGrid.innerHTML = utResults.map((c, i) =>
      renderCityCard(c, i, utResults.length, c._stateMeta, true, true)
    ).join('');
  } else {
    utsDivider.style.display = 'none';
    utsGrid.innerHTML = '';
  }

  if (!stateResults.length && !utResults.length) {
    statesDivider.style.display = 'none';
    utsDivider.style.display    = 'none';
    statesGrid.innerHTML = `
      <div class="no-results">
        <span class="no-results-icon">🔍</span>
        <h3>No results for "${query}"</h3>
        <p>Try different keywords. Results only include currently loaded states.</p>
      </div>`;
  }
}

function clearSearch() {
  searchQuery = '';
  document.getElementById('searchInput').value = '';
  document.getElementById('cbClearBtn').classList.remove('visible');
  document.getElementById('globalSearchBanner').classList.remove('visible');
  isGlobalSearch = false;
  showSingleStateMode();
  buildFilters(allCities);
  renderSingleState();
}

// ══════════════════════════════════════════════════
// EXPLORE INDIA SECTION
// ══════════════════════════════════════════════════
function buildCatPills() {
  const wrap = document.getElementById('catPills');
  wrap.innerHTML = EXPLORE_CATEGORIES.map((cat, i) =>
    `<button class="cat-pill ${i === 0 ? 'active' : ''}" data-cat="${cat.label}" onclick="setExploreFilter('${cat.label}', this)">
       <span class="cat-pill-emoji">${cat.emoji}</span>${cat.label}
     </button>`
  ).join('');
}

function setExploreFilter(cat, btn) {
  exploreFilter = cat;
  document.querySelectorAll('.cat-pill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderExploreSection();
}

function handleExploreSearch(val) {
  exploreQuery = val.trim();
  renderExploreSection();
}

function renderExploreSection() {
  let items = [...exploreAllCities];

  if (exploreQuery) items = items.filter(c => matchesQuery(c, exploreQuery));
  if (exploreFilter !== 'All') items = items.filter(c => matchesCityFilter(c, exploreFilter));

  const stateItems = items.filter(c => !UT_IDS.has(c._stateId));
  const utItems    = items.filter(c =>  UT_IDS.has(c._stateId));

  const statesSec = document.getElementById('exploreStatesSection');
  const utsSec    = document.getElementById('exploreUtsSection');
  const noRes     = document.getElementById('exploreNoResults');

  if (!items.length) {
    statesSec.style.display = 'none';
    utsSec.style.display    = 'none';
    noRes.style.display     = '';
    return;
  }

  noRes.style.display = 'none';

  if (stateItems.length) {
    statesSec.style.display = '';
    document.getElementById('exploreStatesCount').textContent = `${stateItems.length} destinations`;
    document.getElementById('exploreStatesGrid').innerHTML = stateItems.map((c, i) =>
      renderCityCard(c, i, stateItems.length, c._stateMeta, false, true)
    ).join('');
  } else {
    statesSec.style.display = 'none';
  }

  if (utItems.length) {
    utsSec.style.display = '';
    document.getElementById('exploreUtsCount').textContent = `${utItems.length} destinations`;
    document.getElementById('exploreUtsGrid').innerHTML = utItems.map((c, i) =>
      renderCityCard(c, i, utItems.length, c._stateMeta, true, true)
    ).join('');
  } else {
    utsSec.style.display = 'none';
  }
}

// ══════════════════════════════════════════════════
// CARD RENDERER
// ✅ FIX 2: cityUrl uses /city?state= (Express route)
// ══════════════════════════════════════════════════
function renderCityCard(city, idx, total, stateMeta, isUT, showStateLabel = false) {
  const isFeatured = idx === 0 && total > 2;
  const delay      = Math.min(idx * 55, 450);
  const cityUrl    = `/city?state=${stateMeta.id}&id=${city.id}`;
  const altPillClass = isUT ? 'card-altitude-pill ut' : 'card-altitude-pill';
  const cardClass    = isUT ? 'city-card ut-card' : 'city-card';
  const tags         = (city.tags || []).slice(0, 3);

  return `
    <a href="${cityUrl}" class="${cardClass} ${isFeatured ? 'featured' : ''}" style="animation-delay:${delay}ms">
      <div class="card-img-wrap">
        <img class="card-img"
             src="${city.hero_image}"
             alt="${city.name}"
             loading="${idx < 4 ? 'eager' : 'lazy'}"
             onerror="this.src='https://images.unsplash.com/photo-1626621331169-5f34be280ed9?w=800&q=80'" />
        <div class="card-img-overlay"></div>
        <div class="card-shimmer"></div>
        <div class="card-badges-top">
          <span class="card-type-pill">${city.type}</span>
          <span class="${altPillClass}">${city.altitude_display || ''}</span>
        </div>
      </div>
      <div class="card-body-over">
        ${showStateLabel ? `<div class="card-state-label">${stateMeta.emoji} ${stateMeta.name}</div>` : ''}
        <div class="card-region">${city.region || ''}${city.district ? ' · ' + city.district : ''}</div>
        <h2 class="card-name">${city.name}</h2>
        <p class="card-tagline">${city.tagline || ''}</p>
        ${tags.length ? `<div class="card-tags">${tags.map(t => `<span class="card-tag">${t}</span>`).join('')}</div>` : ''}
        <div class="card-footer">
          <div class="card-meta-row">
            ${city.best_time ? `<span class="card-meta-item">🗓 ${city.best_time.split(',')[0]}</span>` : ''}
            ${city.distance_delhi_km ? `<span class="card-meta-item">📍 ${city.distance_delhi_km}km</span>` : ''}
            ${city.places ? `<span class="card-meta-item">🏛 ${city.places.length} places</span>` : ''}
          </div>
          <span class="card-explore-btn">Explore →</span>
        </div>
      </div>
    </a>`;
}

// ══════════════════════════════════════════════════
// SEARCH & FILTER
// ══════════════════════════════════════════════════
function matchesQuery(city, q) {
  const lower = q.toLowerCase();
  return (
    city.name.toLowerCase().includes(lower) ||
    (city.tagline || '').toLowerCase().includes(lower) ||
    (city.type || '').toLowerCase().includes(lower) ||
    (city.region || '').toLowerCase().includes(lower) ||
    (city.district || '').toLowerCase().includes(lower) ||
    (city.tags || []).some(t => t.toLowerCase().includes(lower)) ||
    (city.overview || '').toLowerCase().includes(lower) ||
    (city.cuisine || []).some(c => c.toLowerCase().includes(lower)) ||
    (city.places || []).some(p =>
      (p.name || '').toLowerCase().includes(lower) ||
      (p.category || '').toLowerCase().includes(lower) ||
      (p.subcategory || '').toLowerCase().includes(lower) ||
      (p.description || '').toLowerCase().includes(lower)
    )
  );
}

function matchesCityFilter(city, filter) {
  const f = filter.toLowerCase();
  if ((city.type || '').toLowerCase() === f) return true;
  if ((city.tags || []).some(t => t.toLowerCase().includes(f))) return true;
  if ((city.type || '').toLowerCase().includes(f)) return true;
  return false;
}

function handleSearch() {
  searchQuery = document.getElementById('searchInput').value.trim();
  const clearBtn = document.getElementById('cbClearBtn');

  if (!searchQuery) { clearSearch(); return; }

  clearBtn.classList.add('visible');
  activeFilter   = 'All';
  isGlobalSearch = true;
  document.querySelectorAll('.filt').forEach(b => b.classList.remove('active'));
  const allBtn = document.querySelector('.filt[data-filter="All"]');
  if (allBtn) allBtn.classList.add('active');

  performGlobalSearch(searchQuery);
}

function setFilter(type, btn) {
  if (isGlobalSearch) { clearSearch(); }
  activeFilter = type;
  document.querySelectorAll('.filt').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderSingleState();
}

function setSort(mode) { sortMode = mode; if (!isGlobalSearch) renderSingleState(); }

function applySortMode(cities) {
  if (sortMode === 'altitude')  return [...cities].sort((a, b) => b.altitude_m - a.altitude_m);
  if (sortMode === 'distance')  return [...cities].sort((a, b) => a.distance_delhi_km - b.distance_delhi_km);
  if (sortMode === 'places')    return [...cities].sort((a, b) => b.places.length - a.places.length);
  return cities;
}

function focusSearch() {
  document.getElementById('searchInput').focus();
  window.scrollTo({ top: document.getElementById('destinations').offsetTop, behavior: 'smooth' });
}

// ══════════════════════════════════════════════════
// UI BUILDERS
// ══════════════════════════════════════════════════
function buildFilters(cities) {
  const types = ['All', ...new Set(cities.map(c => c.type).filter(Boolean))];
  const strip = document.getElementById('filterStrip');
  strip.innerHTML = types.map((t, i) =>
    `<button class="filt ${i === 0 ? 'active' : ''}" data-filter="${t}" onclick="setFilter('${t}', this)">${t}</button>`
  ).join('') +
  `<div class="filter-sep"></div>
   <div class="sort-wrap">
     <span class="sort-label">Sort:</span>
     <select class="sort-select" onchange="setSort(this.value)">
       <option value="default">Featured</option>
       <option value="altitude">By Altitude</option>
       <option value="distance">Nearest to Delhi</option>
       <option value="places">Most Places</option>
     </select>
   </div>`;
}

function updateStateHeader(stateMeta) {
  document.getElementById('shcEyebrow').textContent = stateMeta.region + (UT_IDS.has(stateMeta.id) ? ' · Union Territory' : ' · State');
  document.getElementById('shcTitle').innerHTML = `Explore <em>${stateMeta.name}</em>`;
  document.getElementById('shcDesc').textContent = stateMeta.tagline;
  document.getElementById('shcStats').innerHTML = `
    <div class="shc-stat"><strong>${allCities.length}</strong><span>Destinations</span></div>
    <div class="shc-stat"><strong>${allCities.reduce((s, c) => s + (c.places ? c.places.length : 0), 0)}</strong><span>Places to Visit</span></div>`;
}

function buildStateDropdown(activeId) {
  const sel      = document.getElementById('stateSelect');
  const statesOpts = STATES.map(s => `<option value="${s.id}" ${s.id === activeId ? 'selected' : ''}>${s.emoji} ${s.name}</option>`).join('');
  const utOpts     = UNION_TERRITORIES.map(s => `<option value="${s.id}" ${s.id === activeId ? 'selected' : ''}>${s.emoji} ${s.name}</option>`).join('');
  sel.innerHTML = `<optgroup label="States">${statesOpts}</optgroup><optgroup label="Union Territories">${utOpts}</optgroup>`;
}

function buildStatesBrowser(activeId) {
  document.getElementById('statesGrid').innerHTML = STATES.map(s => `
    <div class="state-card ${s.id === activeId ? 'active-state' : ''}" data-state-id="${s.id}"
         onclick="loadState('${s.id}'); window.scrollTo({top:0,behavior:'smooth'})">
      <span class="sc-emoji">${s.emoji}</span>
      <div class="sc-name">${s.name}</div>
      <div class="sc-region">${s.region}</div>
    </div>`).join('');

  document.getElementById('utsGrid').innerHTML = UNION_TERRITORIES.map(s => `
    <div class="state-card ut-type ${s.id === activeId ? 'active-state' : ''}" data-state-id="${s.id}"
         onclick="loadState('${s.id}'); window.scrollTo({top:0,behavior:'smooth'})">
      <span class="sc-emoji">${s.emoji}</span>
      <div class="sc-name">${s.name}</div>
      <div class="sc-region">${s.region}</div>
      <span class="sc-badge ut">UT</span>
    </div>`).join('');
}

function buildFooterLinks() {
  document.getElementById('footerStateLinks').innerHTML = STATES.slice(0, 8)
    .map(s => `<li><a href="?state=${s.id}" onclick="loadState('${s.id}'); return false">${s.name}</a></li>`)
    .join('');
}

// ══════════════════════════════════════════════════
// HERO SLIDESHOW
// ══════════════════════════════════════════════════
let heroSlideInterval = null;
let heroCurrentSlide  = 0;

const INDIA_SLIDES = [
  'https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=1600&q=80',
  'https://images.unsplash.com/photo-1586500036706-41963de24d8b?w=1600&q=80',
  'https://images.unsplash.com/photo-1605649487212-47bdab064df7?w=1600&q=80',
  'https://images.unsplash.com/photo-1477587458883-47145ed94245?w=1600&q=80',
];

function updateHeroForState(stateMeta) {
  document.getElementById('heroStateName').textContent = stateMeta.name;
  document.getElementById('heroDesc').textContent = stateMeta.tagline;
  const slides = (stateMeta.heroSlides && stateMeta.heroSlides[0] !== 'url1')
    ? stateMeta.heroSlides : INDIA_SLIDES;
  buildHeroSlides(slides);
  const total = allCities.reduce((s, c) => s + (c.places ? c.places.length : 0), 0);
  const el = document.getElementById('heroTotalPlaces');
  if (el) el.textContent = total + '+';
}

function buildHeroSlides(slides) {
  const slidesEl     = document.getElementById('heroSlides');
  const indicatorsEl = document.getElementById('slideIndicators');
  slidesEl.innerHTML = indicatorsEl.innerHTML = '';
  if (heroSlideInterval) clearInterval(heroSlideInterval);

  slides.forEach((src, i) => {
    const s = document.createElement('div');
    s.className = 'hero-slide' + (i === 0 ? ' active' : '');
    s.style.backgroundImage = `url('${src}')`;
    slidesEl.appendChild(s);
    const d = document.createElement('div');
    d.className = 'slide-dot' + (i === 0 ? ' active' : '');
    d.onclick   = () => goToSlide(i);
    indicatorsEl.appendChild(d);
  });

  heroCurrentSlide  = 0;
  heroSlideInterval = setInterval(() => goToSlide((heroCurrentSlide + 1) % slides.length), 6000);
}

function goToSlide(n) {
  document.querySelectorAll('.hero-slide').forEach((s, i) => s.classList.toggle('active', i === n));
  document.querySelectorAll('.slide-dot').forEach((d, i) => d.classList.toggle('active', i === n));
  heroCurrentSlide = n;
}

function initHero() { if (currentState) updateHeroForState(currentState); }

// ══════════════════════════════════════════════════
// NAV
// ══════════════════════════════════════════════════
function initNav() {
  const nav = document.getElementById('mainNav');
  const cb  = document.querySelector('.control-bar');
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 60;
    nav.classList.toggle('scrolled', scrolled);
    cb.classList.toggle('nav-visible', scrolled);
  }, { passive: true });
}

// ══════════════════════════════════════════════════
// SCROLL FADE-IN
// ══════════════════════════════════════════════════
function initScrollFadeIn() {
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: .12 });
  document.querySelectorAll('.fade-in-up').forEach(el => observer.observe(el));
}

main();
</script>
</body>
</html>
