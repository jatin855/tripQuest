<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Host Dashboard — TripAdvisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style> body { font-family: 'Inter', sans-serif; } .playfair { font-family: 'Playfair Display', serif; } </style>
</head>
<body class="bg-gray-50">

<%- include('../partials/navbar', { currentUser, userRole: 'host' }) %>

<div class="pt-20 max-w-6xl mx-auto px-4 py-10">

  <!-- Flash Messages -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 text-sm">
      ✅ <%= success %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm">
      <%= error %>
    </div>
  <% } %>

  <!-- Header -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="playfair text-3xl font-bold text-gray-900">Host Dashboard</h1>
      <p class="text-gray-500 text-sm mt-1">Welcome back, <span class="font-medium text-teal-600"><%= host.name %></span></p>
    </div>
    <a href="/host/create-experience"
       class="bg-teal-600 text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-teal-700 transition-colors shadow-sm">
      + New Experience
    </a>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm text-center">
      <div class="text-3xl font-bold text-gray-900"><%= stats.total %></div>
      <div class="text-xs text-gray-500 mt-1 font-medium">Total</div>
    </div>
    <div class="bg-yellow-50 rounded-2xl p-5 border border-yellow-100 shadow-sm text-center">
      <div class="text-3xl font-bold text-yellow-600"><%= stats.pending %></div>
      <div class="text-xs text-yellow-700 mt-1 font-medium">Pending Review</div>
    </div>
    <div class="bg-green-50 rounded-2xl p-5 border border-green-100 shadow-sm text-center">
      <div class="text-3xl font-bold text-green-600"><%= stats.approved %></div>
      <div class="text-xs text-green-700 mt-1 font-medium">Live</div>
    </div>
    <div class="bg-red-50 rounded-2xl p-5 border border-red-100 shadow-sm text-center">
      <div class="text-3xl font-bold text-red-500"><%= stats.rejected %></div>
      <div class="text-xs text-red-600 mt-1 font-medium">Rejected</div>
    </div>
  </div>

  <!-- Experiences Table -->
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="font-semibold text-gray-800">My Experiences</h2>
    </div>

    <% if (experiences.length === 0) { %>
      <div class="text-center py-16 text-gray-500">
        <div class="text-5xl mb-3">🎭</div>
        <p class="font-medium mb-2">No experiences yet</p>
        <p class="text-sm mb-4">Create your first experience and share your culture!</p>
        <a href="/host/create-experience"
           class="text-teal-600 font-semibold text-sm hover:underline">
          Create Experience →
        </a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider">
            <tr>
              <th class="px-6 py-3 text-left">Title</th>
              <th class="px-6 py-3 text-left">Category</th>
              <th class="px-6 py-3 text-left">City</th>
              <th class="px-6 py-3 text-left">Price</th>
              <th class="px-6 py-3 text-left">Status</th>
              <th class="px-6 py-3 text-left">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% experiences.forEach(exp => { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-medium text-gray-900 max-w-xs truncate"><%= exp.title %></div>
                <div class="text-xs text-gray-400 mt-0.5">
                  <%= new Date(exp.createdAt).toLocaleDateString('en-IN') %>
                </div>
              </td>
              <td class="px-6 py-4 text-gray-600"><%= exp.category %></td>
              <td class="px-6 py-4 text-gray-600"><%= exp.city %></td>
              <td class="px-6 py-4">
                <% if (exp.isFree) { %>
                  <span class="text-green-600 font-semibold">Free</span>
                <% } else { %>
                  <span class="text-gray-800">₹<%= exp.price %></span>
                <% } %>
              </td>
              <td class="px-6 py-4">
                <% if (exp.status === 'approved') { %>
                  <span class="bg-green-100 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full">Live</span>
                <% } else if (exp.status === 'pending') { %>
                  <span class="bg-yellow-100 text-yellow-700 text-xs font-semibold px-2.5 py-1 rounded-full">Pending</span>
                <% } else { %>
                  <span class="bg-red-100 text-red-700 text-xs font-semibold px-2.5 py-1 rounded-full">Rejected</span>
                <% } %>
                <% if (exp.status === 'rejected' && exp.rejectionReason) { %>
                  <div class="text-xs text-red-500 mt-1 max-w-xs"><%= exp.rejectionReason %></div>
                <% } %>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <% if (exp.status === 'approved') { %>
                    <a href="/experiences/<%= exp.slug %>"
                       class="text-xs text-teal-600 hover:underline font-medium">View</a>
                  <% } %>
                  <a href="/host/edit-experience/<%= exp._id %>"
                     class="text-xs text-blue-600 hover:underline font-medium">Edit</a>
                  <form action="/host/delete-experience/<%= exp._id %>" method="POST"
                        onsubmit="return confirm('Delete this experience?')">
                    <button type="submit"
                            class="text-xs text-red-500 hover:underline font-medium">
                      Delete
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
