<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Create Experience — TripAdvisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style> body { font-family: 'Inter', sans-serif; } .playfair { font-family: 'Playfair Display', serif; } </style>
</head>
<body class="bg-gray-50">

<%- include('../partials/navbar', { currentUser, userRole: 'host' }) %>

<div class="pt-24 pb-16 max-w-3xl mx-auto px-4">

  <div class="text-center mb-8">
    <h1 class="playfair text-3xl font-bold text-gray-900 mb-2">Create New Experience</h1>
    <p class="text-gray-500 text-sm">Fill in the details. Your experience will be reviewed before going live.</p>
  </div>

  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm"><%= error %></div>
  <% } %>

  <form action="/host/create-experience" method="POST"
        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 space-y-7">

    <!-- Section: Basic Info -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📋 Basic Information</h2>
      <div class="space-y-4">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Title *</label>
          <input type="text" name="title" required
                 placeholder="e.g. Traditional Banarasi Silk Weaving Workshop"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Category *</label>
          <select name="category" required
                  class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 bg-white">
            <option value="">Select a category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Description *</label>
          <textarea name="description" required rows="4"
                    placeholder="Describe your experience in detail. What will guests do, see, and learn?"
                    class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            Highlights <span class="text-gray-400 font-normal">(one per line)</span>
          </label>
          <textarea name="highlights" rows="3"
                    placeholder="Learn 3 traditional weaving patterns&#10;Take home your own creation&#10;Meet the master weaver family"
                    class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"></textarea>
        </div>
      </div>
    </div>

    <!-- Section: Location -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📍 Location</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Place Name *</label>
          <input type="text" name="placeName" required placeholder="e.g. Old City Varanasi"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">City *</label>
          <input type="text" name="city" required placeholder="e.g. Varanasi"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">State</label>
          <input type="text" name="state" placeholder="e.g. Uttar Pradesh"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Country</label>
          <input type="text" name="country" value="India"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Address</label>
          <input type="text" name="address" placeholder="Street address or landmark"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <!-- Section: Schedule -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📅 Schedule</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Date</label>
          <input type="date" name="date"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Time</label>
          <input type="text" name="time" placeholder="e.g. 10:00 AM"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Duration</label>
          <input type="text" name="duration" placeholder="e.g. 2 hours"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <!-- Section: Pricing -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">💰 Pricing</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3 border border-gray-200 cursor-pointer">
          <input type="checkbox" name="isFree" id="isFree"
                 class="w-4 h-4 accent-teal-600"
                 onchange="document.getElementById('priceField').disabled = this.checked" />
          <label for="isFree" class="text-sm font-medium text-gray-700 cursor-pointer">
            This is a Free Experience
          </label>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Price per Person (₹)</label>
          <input type="number" name="price" id="priceField" min="0" placeholder="0"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Max Guests</label>
          <input type="number" name="maxGuests" min="1" value="20"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Languages (comma-separated)</label>
          <input type="text" name="languages" placeholder="Hindi, English"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <!-- Section: Images -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">🖼 Images</h2>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
          Image URLs <span class="text-gray-400 font-normal">(comma-separated)</span>
        </label>
        <textarea name="images" rows="2"
                  placeholder="https://example.com/image1.jpg, https://example.com/image2.jpg"
                  class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"></textarea>
        <p class="text-xs text-gray-400 mt-1">Paste public image URLs. Cloudinary integration can be added later.</p>
      </div>
    </div>

    <!-- Section: Contact -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📞 Contact Info</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Contact Email</label>
          <input type="email" name="contactEmail" placeholder="your@email.com"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Contact Phone</label>
          <input type="text" name="contactPhone" placeholder="+91 98765 43210"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-sm text-amber-800">
      ⏳ Your experience will be reviewed by our team before going live. This usually takes 24 hours.
    </div>

    <div class="flex gap-3">
      <a href="/host/dashboard"
         class="flex-1 text-center border border-gray-300 text-gray-700 font-semibold py-3 rounded-xl hover:bg-gray-50 transition-colors text-sm">
        Cancel
      </a>
      <button type="submit"
              class="flex-2 w-full bg-teal-600 text-white font-semibold py-3 rounded-xl hover:bg-teal-700 transition-colors shadow-md text-sm">
        Submit for Review →
      </button>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>
</body>
</html>
