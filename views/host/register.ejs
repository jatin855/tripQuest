<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Become a Host — TripAdvisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style> body { font-family: 'Inter', sans-serif; } .playfair { font-family: 'Playfair Display', serif; } </style>
</head>
<body class="bg-gray-50">

<%- include('../partials/navbar', { currentUser, userRole: null }) %>

<div class="pt-24 pb-16 max-w-3xl mx-auto px-4">

  <!-- Header -->
  <div class="text-center mb-10">
    <span class="inline-block bg-teal-50 text-teal-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
      Join Our Host Community
    </span>
    <h1 class="playfair text-4xl font-bold text-gray-900 mb-3">Become a Local Host</h1>
    <p class="text-gray-500 text-lg max-w-xl mx-auto">
      Share your culture, craft, or local expertise with curious travelers from around the world.
    </p>
  </div>

  <!-- Flash Messages -->
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm">
      <%= error %>
    </div>
  <% } %>

  <!-- Form -->
  <form action="/host/register" method="POST"
        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 space-y-6">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Your City *</label>
        <input type="text" name="hostCity" required placeholder="e.g. Varanasi"
               class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">State *</label>
        <input type="text" name="hostState" required placeholder="e.g. Uttar Pradesh"
               class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Country</label>
      <input type="text" name="hostCountry" value="India" placeholder="India"
             class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400" />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Host Bio *</label>
      <textarea name="hostBio" required rows="3"
                placeholder="Tell travelers about yourself — your background, passion, and what makes you unique..."
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-3">Areas of Expertise (select all that apply)</label>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <% [
          'Cultural Workshops','Food & Cooking','Heritage Walks',
          'Music & Dance','Art & Craft','Storytelling',
          'Spiritual Experiences','Local Guided Tours','Festivals & Melas',
          'Photography','Community Events','Other'
        ].forEach(exp => { %>
          <label class="flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 cursor-pointer hover:border-teal-400 hover:bg-teal-50 transition-colors text-sm">
            <input type="checkbox" name="hostExpertise" value="<%= exp %>"
                   class="accent-teal-600 rounded" />
            <%= exp %>
          </label>
        <% }) %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Why do you want to host? *</label>
      <textarea name="hostWhyJoin" required rows="3"
                placeholder="What motivates you to share your culture with travelers?"
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"></textarea>
    </div>

    <div class="bg-teal-50 border border-teal-100 rounded-xl p-4 text-sm text-teal-800">
      ✅ By submitting this form, you agree to host authentic, respectful, and safe cultural experiences for all travelers.
    </div>

    <button type="submit"
            class="w-full bg-teal-600 text-white font-semibold py-3 rounded-xl hover:bg-teal-700 transition-colors text-base shadow-md">
      Submit Host Application →
    </button>
  </form>
</div>

<%- include('../partials/footer') %>
</body>
</html>
