<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Experience — TripAdvisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style> body { font-family: 'Inter', sans-serif; } .playfair { font-family: 'Playfair Display', serif; } </style>
</head>
<body class="bg-gray-50">

<%- include('../partials/navbar', { currentUser, userRole: 'host' }) %>

<div class="pt-24 pb-16 max-w-3xl mx-auto px-4">

  <div class="flex items-center gap-3 mb-8">
    <a href="/host/dashboard" class="text-gray-400 hover:text-teal-600 transition-colors">
      ← Back to Dashboard
    </a>
  </div>

  <div class="text-center mb-8">
    <h1 class="playfair text-3xl font-bold text-gray-900 mb-2">Edit Experience</h1>
    <p class="text-gray-500 text-sm">Changes will be sent for re-review before going live.</p>
  </div>

  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm"><%= error %></div>
  <% } %>

  <form action="/host/edit-experience/<%= experience._id %>" method="POST"
        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 space-y-7">

    <!-- Basic Info -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📋 Basic Information</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Title *</label>
          <input type="text" name="title" required value="<%= experience.title %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Category *</label>
          <select name="category" required
                  class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 bg-white">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= experience.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Description *</label>
          <textarea name="description" required rows="4"
                    class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"><%= experience.description %></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Highlights (one per line)</label>
          <textarea name="highlights" rows="3"
                    class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"><%= experience.highlights ? experience.highlights.join('\n') : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Location -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📍 Location</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Place Name *</label>
          <input type="text" name="placeName" required value="<%= experience.placeName %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">City *</label>
          <input type="text" name="city" required value="<%= experience.city %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">State</label>
          <input type="text" name="state" value="<%= experience.state || '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Country</label>
          <input type="text" name="country" value="<%= experience.country || 'India' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Address</label>
          <input type="text" name="address" value="<%= experience.address || '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <!-- Schedule & Pricing (same structure as create, pre-filled) -->
    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📅 Schedule</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Date</label>
          <input type="date" name="date"
                 value="<%= experience.date ? new Date(experience.date).toISOString().split('T')[0] : '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Time</label>
          <input type="text" name="time" value="<%= experience.time || '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Duration</label>
          <input type="text" name="duration" value="<%= experience.duration || '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">💰 Pricing</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3 border border-gray-200">
          <input type="checkbox" name="isFree" id="isFree" <%= experience.isFree ? 'checked' : '' %>
                 class="w-4 h-4 accent-teal-600"
                 onchange="document.getElementById('priceField').disabled = this.checked" />
          <label for="isFree" class="text-sm font-medium text-gray-700">Free Experience</label>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Price per Person (₹)</label>
          <input type="number" name="price" id="priceField" value="<%= experience.price || 0 %>"
                 <%= experience.isFree ? 'disabled' : '' %>
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Max Guests</label>
          <input type="number" name="maxGuests" value="<%= experience.maxGuests || 20 %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Languages</label>
          <input type="text" name="languages"
                 value="<%= experience.languages ? experience.languages.join(', ') : 'Hindi, English' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">🖼 Images</h2>
      <textarea name="images" rows="2"
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 resize-none"><%= experience.images ? experience.images.join(', ') : '' %></textarea>
    </div>

    <div>
      <h2 class="font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-100">📞 Contact</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Contact Email</label>
          <input type="email" name="contactEmail" value="<%= experience.contactEmail || '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Contact Phone</label>
          <input type="text" name="contactPhone" value="<%= experience.contactPhone || '' %>"
                 class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400"/>
        </div>
      </div>
    </div>

    <div class="flex gap-3">
      <a href="/host/dashboard"
         class="flex-1 text-center border border-gray-300 text-gray-700 font-semibold py-3 rounded-xl hover:bg-gray-50 transition-colors text-sm">
        Cancel
      </a>
      <button type="submit"
              class="flex-1 bg-teal-600 text-white font-semibold py-3 rounded-xl hover:bg-teal-700 transition-colors shadow-md text-sm">
        Save & Re-Submit →
      </button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
</body>
</html>
