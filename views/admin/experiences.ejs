<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin — Experience Moderation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-gray-100">

<%- include('../partials/navbar', { currentUser, userRole: 'admin' }) %>

<div class="pt-20 max-w-7xl mx-auto px-4 py-10">

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Experience Moderation</h1>
      <p class="text-gray-500 text-sm mt-1">Review and approve experiences before they go live.</p>
    </div>
  </div>

  <!-- Flash Messages -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 text-sm">✅ <%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm"><%= error %></div>
  <% } %>

  <!-- Counts + Filters -->
  <div class="flex flex-wrap gap-3 mb-6">
    <a href="/admin/experiences"
       class="px-5 py-2 rounded-full text-sm font-medium transition-colors
              <%= activeFilter === 'all' ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-gray-300' %>">
      All (<%= counts.all %>)
    </a>
    <a href="/admin/experiences?status=pending"
       class="px-5 py-2 rounded-full text-sm font-medium transition-colors
              <%= activeFilter === 'pending' ? 'bg-yellow-500 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-yellow-300' %>">
      Pending (<%= counts.pending %>)
    </a>
    <a href="/admin/experiences?status=approved"
       class="px-5 py-2 rounded-full text-sm font-medium transition-colors
              <%= activeFilter === 'approved' ? 'bg-green-600 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-green-300' %>">
      Approved (<%= counts.approved %>)
    </a>
    <a href="/admin/experiences?status=rejected"
       class="px-5 py-2 rounded-full text-sm font-medium transition-colors
              <%= activeFilter === 'rejected' ? 'bg-red-500 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-red-300' %>">
      Rejected (<%= counts.rejected %>)
    </a>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <% if (experiences.length === 0) { %>
      <div class="text-center py-16 text-gray-500">
        <p>No experiences in this category.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider">
            <tr>
              <th class="px-6 py-3 text-left">Experience</th>
              <th class="px-6 py-3 text-left">Host</th>
              <th class="px-6 py-3 text-left">Category</th>
              <th class="px-6 py-3 text-left">City</th>
              <th class="px-6 py-3 text-left">Status</th>
              <th class="px-6 py-3 text-left">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% experiences.forEach(exp => { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-medium text-gray-900 max-w-xs"><%= exp.title %></div>
                <div class="text-xs text-gray-400 mt-0.5">
                  Submitted: <%= new Date(exp.createdAt).toLocaleDateString('en-IN') %>
                </div>
              </td>
              <td class="px-6 py-4">
                <div class="font-medium text-gray-800">
                  <%= exp.hostId ? exp.hostId.username : exp.hostName %>
                </div>
                <div class="text-xs text-gray-400">
                  <%= exp.hostId ? exp.hostId.email : '' %>
                </div>
              </td>
              <td class="px-6 py-4 text-gray-600"><%= exp.category %></td>
              <td class="px-6 py-4 text-gray-600"><%= exp.city %></td>
              <td class="px-6 py-4">
                <% if (exp.status === 'approved') { %>
                  <span class="bg-green-100 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full">Approved</span>
                <% } else if (exp.status === 'pending') { %>
                  <span class="bg-yellow-100 text-yellow-700 text-xs font-semibold px-2.5 py-1 rounded-full">Pending</span>
                <% } else { %>
                  <span class="bg-red-100 text-red-700 text-xs font-semibold px-2.5 py-1 rounded-full">Rejected</span>
                <% } %>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2 flex-wrap">

                  <!-- Approve -->
                  <% if (exp.status !== 'approved') { %>
                    <form action="/admin/experiences/<%= exp._id %>/approve" method="POST">
                      <button type="submit"
                              class="bg-green-100 text-green-700 text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-green-200 transition-colors">
                        ✓ Approve
                      </button>
                    </form>
                  <% } %>

                  <!-- Reject with reason modal -->
                  <% if (exp.status !== 'rejected') { %>
                    <button onclick="openRejectModal('<%= exp._id %>')"
                            class="bg-red-100 text-red-700 text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-red-200 transition-colors">
                      ✗ Reject
                    </button>
                  <% } %>

                  <!-- Feature toggle -->
                  <form action="/admin/experiences/<%= exp._id %>/feature" method="POST">
                    <button type="submit"
                            class="bg-purple-100 text-purple-700 text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-purple-200 transition-colors">
                      <%= exp.isFeatured ? '★ Unfeature' : '☆ Feature' %>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 flex">
  <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4 shadow-xl">
    <h3 class="font-bold text-gray-900 mb-3">Reject Experience</h3>
    <p class="text-sm text-gray-500 mb-4">Provide a reason so the host can improve their submission.</p>
    <form id="rejectForm" method="POST">
      <textarea name="rejectionReason" rows="3" required
                placeholder="e.g. Description is too vague. Please add more details about what guests will experience."
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm mb-4 focus:outline-none focus:ring-2 focus:ring-red-300 resize-none"></textarea>
      <div class="flex gap-3">
        <button type="button" onclick="closeRejectModal()"
                class="flex-1 border border-gray-300 text-gray-700 py-2.5 rounded-xl text-sm hover:bg-gray-50 transition-colors">
          Cancel
        </button>
        <button type="submit"
                class="flex-1 bg-red-500 text-white py-2.5 rounded-xl text-sm font-semibold hover:bg-red-600 transition-colors">
          Reject Experience
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function openRejectModal(id) {
    document.getElementById('rejectForm').action = `/admin/experiences/${id}/reject`;
    document.getElementById('rejectModal').classList.remove('hidden');
    document.getElementById('rejectModal').classList.add('flex');
  }
  function closeRejectModal() {
    document.getElementById('rejectModal').classList.add('hidden');
    document.getElementById('rejectModal').classList.remove('flex');
  }
</script>

<%- include('../partials/footer') %>
</body>
</html>
