<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reviews – TripQuest | Share Your Travel Story</title>
  <meta name="description" content="Read and share honest travel reviews for cities across India. Help fellow travellers discover the best places to visit." />
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheet/reviews.css" />
</head>
<body>

<!-- ══════════ NAVBAR ══════════ -->
<header class="navbar">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/home" class="flex items-center gap-2 no-underline">
      <div style="width:36px;height:36px;background:#34E0A1;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;box-shadow:0 2px 8px rgba(52,224,161,.35)">🦉</div>
      <span style="font-size:1.2rem;font-weight:900;color:#1a1a1a;letter-spacing:-0.02em">Trip<span style="color:#00AA6C">Advisor</span></span>
    </a>
    <ul class="hidden md:flex gap-7 text-sm list-none" style="font-weight:700">
      <li class="nav-link" onclick="window.location.href='/home'">Home</li>
      <li class="nav-link" onclick="window.location.href='/explore'">Explore</li>
      <li class="nav-link" onclick="window.location.href='/experiences'">Experiences</li>
      <li class="nav-link" onclick="window.location.href='/marketplace'">Marketplace</li>
      <li class="nav-link active" onclick="window.location.href='/reviews'">Reviews</li>
    </ul>
    <div class="flex items-center gap-3">
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="greeting-pill hidden md:inline-flex">
          👋 Hey, <%= user.name.split(' ')[0] %>!
        </span>
        <a href="/profile" class="avatar-nav" title="Go to Profile">
          <%= user.name.charAt(0).toUpperCase() %>
        </a>
        <a href="/logout" class="btn-logout">Logout</a>
      <% } else { %>
        <a href="/login" style="font-size:0.85rem;font-weight:800;color:#00AA6C;text-decoration:none">Sign In</a>
        <a href="/register">
          <button class="btn-cta px-5 py-2 text-sm">Get Started</button>
        </a>
      <% } %>
    </div>
  </nav>
</header>

<!-- ══════════ HERO ══════════ -->
<section class="reviews-hero">
  <div class="hero-particles" id="heroParticles"></div>
  <div class="hero-content">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      <span>COMMUNITY REVIEWS</span>
    </div>
    <h1>Share Your <span class="green-text">Travel Story</span></h1>
    <p class="hero-subtitle">Help fellow travellers discover the real India — one honest review at a time.</p>
    <div class="hero-stats-row">
      <div class="hero-stat">
        <span class="hero-stat-val" id="totalReviewsStat">0</span>
        <span class="hero-stat-label">Reviews</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-val">36</span>
        <span class="hero-stat-label">States & UTs</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-val">350+</span>
        <span class="hero-stat-label">Cities</span>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ MAIN CONTENT ══════════ -->
<main class="reviews-main">

  <!-- ── PLACE SELECTOR ── -->
  <section class="selector-section" id="selectorSection">
    <div class="selector-card">
      <div class="selector-header">
        <div class="selector-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00AA6C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div>
          <h2 class="selector-title">Select a Place</h2>
          <p class="selector-desc">Choose a state and city to view or write reviews</p>
        </div>
      </div>
      <div class="dropdowns-row">
        <div class="dropdown-group">
          <label for="stateSelect">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3z"/><path d="M12 3v18M3 12h18"/></svg>
            State / UT
          </label>
          <div class="select-wrapper">
            <select id="stateSelect">
              <option value="">— Choose State —</option>
            </select>
          </div>
        </div>
        <div class="dropdown-group">
          <label for="citySelect">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            City
          </label>
          <div class="select-wrapper">
            <select id="citySelect" disabled>
              <option value="">— Choose City —</option>
            </select>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── REVIEWS DISPLAY ── -->
  <section class="reviews-display-section" id="reviewsDisplay" style="display:none;">

    <!-- Stats bar -->
    <div class="stats-summary-card" id="statsSummary" style="display:none;">
      <div class="stats-left">
        <div class="stats-avg-wrap">
          <span class="stats-avg-num" id="statsAvg">0.0</span>
          <div class="stats-avg-meta">
            <div class="stats-stars-display" id="statsStars"></div>
            <span class="stats-total" id="statsTotal">0 reviews</span>
          </div>
        </div>
      </div>
      <div class="stats-bars" id="statsBars">
        <!-- Injected by JS -->
      </div>
    </div>

    <!-- Header row -->
    <div class="reviews-header-row">
      <div>
        <h2 class="reviews-section-title" id="reviewsTitle">Reviews</h2>
        <p class="reviews-count" id="reviewsCount"></p>
      </div>
      <div class="reviews-actions">
        <div class="sort-wrap" id="sortWrap" style="display:none;">
          <label for="sortSelect">Sort:</label>
          <select id="sortSelect">
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
        <% if (typeof user !== 'undefined' && user) { %>
          <button class="btn-write-review" id="writeReviewBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Write a Review
          </button>
        <% } else { %>
          <a href="/login" class="btn-write-review">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M12 11V3"/><path d="M9 6l3-3 3 3"/></svg>
            Login to Review
          </a>
        <% } %>
      </div>
    </div>

    <!-- Review cards grid -->
    <div class="reviews-grid" id="reviewsGrid">
      <!-- Cards injected by JS -->
    </div>
  </section>

  <!-- ── SUBMIT FORM (hidden until button clicked) ── -->
  <% if (typeof user !== 'undefined' && user) { %>
  <section class="submit-section" id="submitSection" style="display:none;">
    <div class="submit-card">
      <div class="submit-header">
        <div class="submit-icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00AA6C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <div>
          <h2 class="submit-title">Write Your Review</h2>
          <p class="submit-desc">Share your travel experience and help others plan better trips</p>
        </div>
      </div>

      <div class="form-inner">
        <div class="form-row">
          <div class="form-group">
            <label>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Your Name
            </label>
            <input type="text" id="usernameField" value="<%= user.name %>" readonly />
          </div>
          <div class="form-group">
            <label>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Place
            </label>
            <input type="text" id="placeDisplay" readonly placeholder="Select a city above" />
          </div>
        </div>

        <div class="form-group">
          <label>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Your Rating
          </label>
          <div class="star-rating-wrap">
            <div class="star-rating" id="starRating">
              <span data-val="1" title="Poor">★</span>
              <span data-val="2" title="Fair">★</span>
              <span data-val="3" title="Good">★</span>
              <span data-val="4" title="Very Good">★</span>
              <span data-val="5" title="Excellent">★</span>
            </div>
            <span class="rating-label" id="ratingLabel">Click to rate</span>
          </div>
          <input type="hidden" id="ratingInput" value="0"/>
        </div>

        <div class="form-group">
          <label>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Your Review
          </label>
          <textarea id="reviewText" rows="5" placeholder="Share your experience — what made it special? What should travellers know? Tips, highlights, anything authentic..." maxlength="1000"></textarea>
          <div class="textarea-footer">
            <span class="char-count" id="charCount">0 / 1000</span>
            <span class="min-hint">Min. 10 characters</span>
          </div>
        </div>

        <div class="form-actions">
          <button class="btn-cancel" id="cancelReviewBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Cancel
          </button>
          <button class="btn-submit" id="submitReviewBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Submit Review
          </button>
        </div>
        <div id="formMessage" class="form-message"></div>
      </div>
    </div>
  </section>
  <% } %>

</main>

<!-- ══════════ FOOTER ══════════ -->
<footer class="reviews-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div style="width:32px;height:32px;background:#34E0A1;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px">🦉</div>
      <span>Trip<span style="color:#34E0A1">Advisor</span></span>
    </div>
    <p>© 2025 TripQuest Clone • Made with ❤️ for travellers</p>
    <div class="footer-links">
      <a href="/home">Home</a>
      <a href="/explore">Explore</a>
      <a href="/experiences">Experiences</a>
    </div>
  </div>
</footer>

<!-- ══════════ SCROLL TO TOP ══════════ -->
<button class="scroll-top-btn" id="scrollTopBtn" title="Back to top">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
</button>

<script src="/javscripts/reviews.js"></script>
</body>
</html>