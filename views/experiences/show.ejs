<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= experience.title %> — TripAdvisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .playfair { font-family: 'Playfair Display', serif; }
  </style>
</head>
<body class="bg-white text-gray-800">

<%- include('../partials/navbar', { currentUser, userRole: typeof userRole !== 'undefined' ? userRole : null }) %>

<!-- Hero Image -->
<div class="pt-16 relative h-72 md:h-96 bg-gradient-to-br from-teal-600 to-emerald-700 overflow-hidden">
  <% if (experience.images && experience.images.length > 0) { %>
    <img src="<%= experience.images[0] %>" alt="<%= experience.title %>"
         class="w-full h-full object-cover opacity-80" />
  <% } %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
  <div class="absolute bottom-6 left-6 right-6">
    <span class="inline-block bg-white/20 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1 rounded-full mb-2">
      <%= experience.category %>
    </span>
    <h1 class="playfair text-3xl md:text-4xl font-bold text-white">
      <%= experience.title %>
    </h1>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 lg:grid-cols-3 gap-10">

  <!-- Left: Details -->
  <div class="lg:col-span-2 space-y-8">

    <!-- Quick Info Bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <div class="text-2xl mb-1">📍</div>
        <div class="text-xs text-gray-500">Location</div>
        <div class="font-semibold text-sm text-gray-800"><%= experience.city %></div>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <div class="text-2xl mb-1">📅</div>
        <div class="text-xs text-gray-500">Date</div>
        <div class="font-semibold text-sm text-gray-800">
          <%= experience.date
            ? new Date(experience.date).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })
            : 'Flexible' %>
        </div>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <div class="text-2xl mb-1">⏱</div>
        <div class="text-xs text-gray-500">Duration</div>
        <div class="font-semibold text-sm text-gray-800"><%= experience.duration || 'TBD' %></div>
      </div>
      <div class="bg-gray-50 rounded-xl p-4 text-center">
        <div class="text-2xl mb-1">👥</div>
        <div class="text-xs text-gray-500">Max Guests</div>
        <div class="font-semibold text-sm text-gray-800"><%= experience.maxGuests %></div>
      </div>
    </div>

    <!-- Description -->
    <div>
      <h2 class="playfair text-2xl font-bold text-gray-900 mb-3">About This Experience</h2>
      <p class="text-gray-600 leading-relaxed"><%= experience.description %></p>
    </div>

    <!-- Highlights -->
    <% if (experience.highlights && experience.highlights.length > 0) { %>
    <div>
      <h2 class="playfair text-2xl font-bold text-gray-900 mb-4">Highlights</h2>
      <ul class="space-y-2">
        <% experience.highlights.forEach(h => { %>
          <li class="flex items-start gap-3 text-gray-700">
            <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <%= h %>
          </li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- Gallery -->
    <% if (experience.images && experience.images.length > 1) { %>
    <div>
      <h2 class="playfair text-2xl font-bold text-gray-900 mb-4">Gallery</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <% experience.images.slice(1).forEach(img => { %>
          <img src="<%= img %>" alt="gallery"
               class="w-full h-40 object-cover rounded-xl hover:opacity-90 transition-opacity cursor-pointer" />
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Languages -->
    <% if (experience.languages && experience.languages.length > 0) { %>
    <div>
      <h3 class="font-semibold text-gray-800 mb-2">Languages</h3>
      <div class="flex flex-wrap gap-2">
        <% experience.languages.forEach(lang => { %>
          <span class="bg-teal-50 text-teal-700 text-sm px-3 py-1 rounded-full border border-teal-100">
            <%= lang %>
          </span>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Right: Sidebar -->
  <div class="space-y-6">

    <!-- Price & CTA Card -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-md sticky top-20">
      <div class="flex items-center justify-between mb-4">
        <div>
          <% if (experience.isFree) { %>
            <span class="text-3xl font-bold text-green-600">Free</span>
          <% } else { %>
            <span class="text-3xl font-bold text-gray-900">₹<%= experience.price %></span>
            <span class="text-gray-500 text-sm"> / person</span>
          <% } %>
        </div>
        <% if (experience.rating > 0) { %>
          <div class="flex items-center gap-1 bg-yellow-50 px-3 py-1.5 rounded-full">
            <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="text-sm font-semibold text-gray-700"><%= experience.rating.toFixed(1) %></span>
          </div>
        <% } %>
      </div>

      <div class="space-y-3 text-sm text-gray-600 mb-6 border-t border-gray-100 pt-4">
        <% if (experience.time) { %>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= experience.time %>
          </div>
        <% } %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
          <%= experience.address || experience.city %>
        </div>
      </div>

      <% if (experience.contactEmail) { %>
        <a href="mailto:<%= experience.contactEmail %>"
           class="block w-full text-center bg-teal-600 text-white font-semibold py-3 rounded-xl hover:bg-teal-700 transition-colors mb-3">
          Contact Host
        </a>
      <% } %>
      <% if (experience.contactPhone) { %>
        <a href="tel:<%= experience.contactPhone %>"
           class="block w-full text-center border border-teal-600 text-teal-600 font-semibold py-3 rounded-xl hover:bg-teal-50 transition-colors">
          Call Host
        </a>
      <% } %>
    </div>

    <!-- Host Card -->
    <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
      <h3 class="font-bold text-gray-900 mb-3">Your Host</h3>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-12 h-12 rounded-full bg-teal-500 flex items-center justify-center text-white font-bold text-lg">
          <%= experience.hostName ? experience.hostName[0].toUpperCase() : 'H' %>
        </div>
        <div>
          <div class="font-semibold text-gray-900"><%= experience.hostName %></div>
          <div class="text-xs text-teal-600">Local Host</div>
        </div>
      </div>
      <% if (experience.hostBio) { %>
        <p class="text-sm text-gray-600 leading-relaxed"><%= experience.hostBio %></p>
      <% } %>
    </div>
  </div>
</div>

<!-- Related Experiences -->
<% if (related && related.length > 0) { %>
<section class="max-w-6xl mx-auto px-4 pb-16">
  <h2 class="playfair text-2xl font-bold text-gray-900 mb-6">
    More Experiences in <%= experience.city %>
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% related.forEach(exp => { %>
      <%- include('../partials/experienceCard', { exp }) %>
    <% }) %>
  </div>
</section>
<% } %>

<%- include('../partials/footer') %>

</body>
</html>
