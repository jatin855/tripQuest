<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Local Experiences — TripQuest</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .playfair { font-family: 'Playfair Display', serif; }
    .line-clamp-2 { display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800">

<%- include('../partials/navbar', { currentUser, userRole: typeof userRole !== 'undefined' ? userRole : null }) %>

<!-- Hero Banner -->
<section class="pt-24 pb-12 bg-gradient-to-br from-teal-700 via-teal-600 to-emerald-600 text-white">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <span class="inline-block bg-white/20 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-4 backdrop-blur-sm">
      Community-Powered Experiences
    </span>
    <h1 class="playfair text-4xl md:text-5xl font-bold mb-4">
      Local Experiences
    </h1>
    <p class="text-teal-100 text-lg max-w-2xl mx-auto mb-8">
      Go beyond sightseeing — join workshops, festivals, and cultural moments hosted by real locals.
    </p>

    <!-- Search bar -->
    <form action="/experiences" method="GET" class="flex flex-col sm:flex-row gap-3 max-w-xl mx-auto">
      <input type="text" name="city" value="<%= filters.city || '' %>"
             placeholder="Search by city or place..."
             class="flex-1 px-5 py-3 rounded-full text-gray-800 text-sm outline-none shadow-md" />
      <button type="submit"
              class="bg-white text-teal-700 font-semibold px-6 py-3 rounded-full hover:bg-teal-50 transition-colors shadow-md">
        Search
      </button>
    </form>
  </div>
</section>

<!-- Filters + Grid -->
<section class="max-w-7xl mx-auto px-4 py-10">

  <!-- Filter Bar -->
  <form action="/experiences" method="GET"
        class="flex flex-wrap gap-3 mb-8 p-4 bg-white rounded-2xl shadow-sm border border-gray-100">

    <!-- Category -->
    <select name="category"
            class="text-sm border border-gray-200 rounded-full px-4 py-2 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-teal-400">
      <option value="">All Categories</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>>
          <%= cat %>
        </option>
      <% }) %>
    </select>

    <!-- City (hidden, used by search above) -->
    <% if (filters.city) { %>
      <input type="hidden" name="city" value="<%= filters.city %>" />
    <% } %>

    <!-- Pricing -->
    <select name="pricing"
            class="text-sm border border-gray-200 rounded-full px-4 py-2 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-teal-400">
      <option value="">Any Price</option>
      <option value="free" <%= filters.pricing === 'free' ? 'selected' : '' %>>Free</option>
      <option value="paid" <%= filters.pricing === 'paid' ? 'selected' : '' %>>Paid</option>
    </select>

    <!-- When -->
    <select name="when"
            class="text-sm border border-gray-200 rounded-full px-4 py-2 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-teal-400">
      <option value="">All Time</option>
      <option value="upcoming" <%= filters.when === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
    </select>

    <button type="submit"
            class="bg-teal-600 text-white text-sm px-5 py-2 rounded-full hover:bg-teal-700 transition-colors font-medium">
      Apply Filters
    </button>

    <% if (Object.values(filters).some(Boolean)) { %>
      <a href="/experiences"
         class="text-sm text-gray-500 px-4 py-2 rounded-full border border-gray-200 hover:border-gray-300 transition-colors">
        Clear All
      </a>
    <% } %>
  </form>

  <!-- Results count -->
  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">
      <span class="font-semibold text-gray-800"><%= experiences.length %></span> experiences found
    </p>
    <% if (currentUser) { %>
      <a href="/host/create-experience"
         class="text-sm bg-teal-600 text-white px-4 py-2 rounded-full font-medium hover:bg-teal-700 transition-colors">
        + List Your Experience
      </a>
    <% } %>
  </div>

  <!-- Experience Cards Grid -->
  <% if (experiences.length === 0) { %>
    <div class="text-center py-20">
      <div class="text-6xl mb-4">🌏</div>
      <h3 class="text-xl font-semibold text-gray-700 mb-2">No experiences found</h3>
      <p class="text-gray-500 mb-6">Try adjusting your filters or search for a different city.</p>
      <a href="/experiences" class="text-teal-600 font-medium hover:underline">View all experiences</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% experiences.forEach(exp => { %>
        <%- include('../partials/experienceCard', { exp }) %>
      <% }) %>
    </div>
  <% } %>

</section>

<!-- Become a Host Banner -->
<section class="bg-gradient-to-r from-emerald-50 to-teal-50 border border-teal-100 mx-4 mb-10 rounded-3xl">
  <div class="max-w-4xl mx-auto px-8 py-12 text-center">
    <h2 class="playfair text-3xl font-bold text-gray-900 mb-3">
      Are you a local expert?
    </h2>
    <p class="text-gray-600 mb-6">
      Share your culture with curious travelers. Become a host and list your experience today.
    </p>
    <a href="/host/register"
       class="inline-block bg-teal-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-teal-700 transition-colors shadow-md">
      Become a Host →
    </a>
  </div>
</section>

<%- include('../partials/footer') %>

</body>
</html>
