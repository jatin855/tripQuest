      const facts = {
        'District': city.district,
        'Region': city.region,
        'Altitude': city.altitude_display + ' above sea level',
        'Type': city.type,
        'Ideal Stay': city.stay_recommended_days + ' days',
        'Language': city.language.join(', '),
        'Nearest Airport': `${city.nearest_airport.name} (${city.nearest_airport.distance_km}km)`,
        'Nearest Railway': `${city.nearest_railhead.name} (${city.nearest_railhead.distance_km}km)`,
        ...(city.facts || {}),
      };
      document.getElementById('factsContainer').innerHTML = Object.entries(facts)
        .map(([k, v]) => `<div class="fact-row"><span class="fact-key">${k}</span><span class="fact-val">${v}</span></div>`)
        .join('');
      document.getElementById('bestTimeBadge').innerHTML = `🗓 Best: ${city.best_time}`;
    }

    // ══════════════════════════════════════════════════
    // RENDER HISTORY
    // ══════════════════════════════════════════════════
    function renderHistory(city) {
      document.getElementById('historyImg').src = city.hero_image;
      document.getElementById('historyImg').alt = city.name;
      document.getElementById('historyCaption').textContent = `${city.name}, ${city.district} District`;
      document.getElementById('historyTitle').innerHTML = `The Story of <em>${city.name}</em>`;
      const firstSentence = city.history.split(/[.!?]/)[0];
      document.getElementById('historyAccent').textContent = `"${firstSentence}."`;
      const remaining = city.history.split(/(?<=[.!?])\s+/).slice(1);
      const mid = Math.ceil(remaining.length / 2);
      document.getElementById('historyBody').innerHTML =
        `<p>${remaining.slice(0, mid).join(' ')}</p>${remaining.length > mid ? `<p>${remaining.slice(mid).join(' ')}</p>` : ''}`;
    }

    // ══════════════════════════════════════════════════
    // RENDER PLACES
    // ══════════════════════════════════════════════════
    function renderPlaces(city) {
      currentCityData = city;
      placesFilter = 'all';
      placesSearch = '';
      document.getElementById('placesTitle').textContent = `Places to Visit in ${city.name}`;

      const categories = ['all', ...new Set(city.places.map(p => p.category))];
      const hasGems = city.hidden_gems && city.hidden_gems.length > 0;

      document.getElementById('filterBar').innerHTML =
        categories.map(cat =>
          `<button class="filter-btn ${cat === 'all' ? 'active' : ''}" data-filter="${cat}"
         onclick="filterPlaces('${cat}', this)">${cat === 'all' ? 'All' : cat}</button>`
        ).join('') +
        (hasGems
          ? `<button class="filter-btn gem-btn" data-filter="hidden-gems"
             onclick="filterPlaces('hidden-gems', this)">💎 Hidden Gems</button>`
          : '');

      applyPlacesFilterAndSearch();
    }

    function filterPlaces(cat, btn) {
      placesFilter = cat;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      placesSearch = '';
      document.getElementById('placesSearch').value = '';
      applyPlacesFilterAndSearch();
    }

    function handlePlacesSearch() {
      placesSearch = document.getElementById('placesSearch').value.toLowerCase().trim();
      if (placesSearch) {
        placesFilter = 'all';
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        const allBtn = document.querySelector('.filter-btn[data-filter="all"]');
        if (allBtn) allBtn.classList.add('active');
      }
      applyPlacesFilterAndSearch();
    }

    function applyPlacesFilterAndSearch() {
      if (!currentCityData) return;
      const grid    = document.getElementById('placesGrid');
      const countEl = document.getElementById('placesSearchCount');

      /* ── Hidden Gems mode ── */
      if (placesFilter === 'hidden-gems') {
        const gems = (currentCityData.hidden_gems || []);
        countEl.textContent = `${gems.length} hidden gems`;
        if (!gems.length) {
          grid.innerHTML = `<div class="no-places"><p>No hidden gems listed for this city yet.</p></div>`;
          return;
        }
        grid.innerHTML = gems.map((place, idx) => `
    <article class="place-card gem-card ${idx === 0 && gems.length > 2 ? 'featured' : ''}" data-category="hidden-gem">
      <div class="card-img-wrap">
        <img class="card-img" src="${place.image || 'https://images.unsplash.com/photo-1562619371-b67825b3b90d?w=600&q=80'}" alt="${place.name}"
             loading="${idx < 3 ? 'eager' : 'lazy'}"
             onerror="this.src='https://images.unsplash.com/photo-1562619371-b67825b3b90d?w=600&q=80'" />
        <div class="card-img-overlay"></div>
        <div class="card-badges">
          <span class="gem-badge">💎 Hidden Gem</span>
          <span class="card-rating"><span class="star">★</span> ${place.rating}</span>
        </div>
      </div>
      <div class="card-body">
        <h3 class="card-title">${place.name}</h3>
        <p class="card-desc">${place.description}</p>
        <div class="card-meta">
          ${place.entry_fee_inr !== undefined ? `<span class="card-meta-item">🎟 ${place.entry_fee_inr === 0 ? 'Free entry' : '₹' + place.entry_fee_inr}</span>` : ''}
          ${place.open_hours ? `<span class="card-meta-item">🕐 ${place.open_hours}</span>` : ''}
          ${place.duration_hrs ? `<span class="card-meta-item">⏱ ${place.duration_hrs}hrs</span>` : ''}
          ${place.distance_from_center_km ? `<span class="card-meta-item">📍 ${place.distance_from_center_km}km from centre</span>` : ''}
        </div>
        ${place.subcategory ? `<div style="margin-top:8px"><span style="font-size:0.7rem;text-transform:uppercase;letter-spacing:.05em;color:var(--gold);font-weight:600">${place.subcategory}</span></div>` : ''}
        ${place.tips ? `<div class="card-tip"><strong>💡 Local Tip:</strong> ${place.tips}</div>` : ''}
      </div>
    </article>`).join('');
        return;
      }

      /* ── Normal places mode ── */
      let filtered = currentCityData.places;
      if (placesFilter !== 'all') filtered = filtered.filter(p => p.category === placesFilter);
      if (placesSearch) {
        filtered = filtered.filter(p =>
          (p.name || '').toLowerCase().includes(placesSearch) ||
          (p.description || '').toLowerCase().includes(placesSearch) ||
          (p.category || '').toLowerCase().includes(placesSearch) ||
          (p.subcategory || '').toLowerCase().includes(placesSearch) ||
          (p.tips || '').toLowerCase().includes(placesSearch)
        );
      }

      countEl.textContent = (placesSearch || placesFilter !== 'all')
        ? `${filtered.length} of ${currentCityData.places.length} places` : '';

      if (!filtered.length) {
        grid.innerHTML = `<div class="no-places"><p>No places found. Try different keywords or clear the search.</p></div>`;
        return;
      }

      grid.innerHTML = filtered.map((place, idx) => `
    <article class="place-card ${idx === 0 && filtered.length > 2 ? 'featured' : ''}" data-category="${place.category}">
      <div class="card-img-wrap">
        <img class="card-img" src="${place.image}" alt="${place.name}"
             loading="${idx < 3 ? 'eager' : 'lazy'}"
             onerror="this.src='https://images.unsplash.com/photo-1626621331169-5f34be280ed9?w=600&q=80'" />
        <div class="card-img-overlay"></div>
        <div class="card-badges">
          <span class="card-cat-badge">${place.subcategory || place.category}</span>
          <span class="card-rating"><span class="star">★</span> ${place.rating}</span>
        </div>
      </div>
      <div class="card-body">
        <h3 class="card-title">${place.name}</h3>
        <p class="card-desc">${place.description}</p>
        <div class="card-meta">
          ${place.entry_fee_inr !== undefined ? `<span class="card-meta-item">🎟 ${place.entry_fee_inr === 0 ? 'Free' : '₹' + place.entry_fee_inr}</span>` : ''}
          ${place.open_hours ? `<span class="card-meta-item">🕐 ${place.open_hours}</span>` : ''}
          ${place.duration_hrs ? `<span class="card-meta-item">⏱ ${place.duration_hrs}hrs</span>` : ''}
          ${place.distance_from_center_km ? `<span class="card-meta-item">📍 ${place.distance_from_center_km}km</span>` : ''}
        </div>
        ${place.tips ? `<div class="card-tip"><strong>💡 Tip:</strong> ${place.tips}</div>` : ''}
      </div>
    </article>`
      ).join('');
    }

    // ══════════════════════════════════════════════════
    // RENDER SEASONS
    // ══════════════════════════════════════════════════
    function renderSeasons(city) {
      const bestLower = city.best_time.toLowerCase();
      document.getElementById('seasonsGrid').innerHTML = SEASONS.map(s => {
        const rec = bestLower.includes(s.name.toLowerCase()) ||
          bestLower.includes(s.months.split(' ')[0].toLowerCase());
        return `
    <div class="season-card ${rec ? 'recommended' : ''}">
      ${rec ? '<div class="season-rec-tag">Recommended</div>' : ''}
      <span class="season-icon">${s.icon}</span>
      <div class="season-name">${s.name}</div>
      <div class="season-months">${s.months}</div>
      <div class="season-temp">${city.temp_summer_c} (summer) · ${city.temp_winter_c} (winter)</div>
      <p class="season-desc">${s.desc}</p>
    </div>`;
      }).join('');
    }

    // ══════════════════════════════════════════════════
    // RENDER TRAVEL
    // ══════════════════════════════════════════════════
    function renderTravel(city) {
      document.getElementById('travelLead').textContent = `${city.name} is accessible by air, rail, and road.`;
      document.getElementById('travelGrid').innerHTML = [
        {
          icon: '✈️', mode: 'By Air',
          detail: `Nearest airport: ${city.nearest_airport.name} (${city.nearest_airport.distance_km}km, code: ${city.nearest_airport.code}).`,
          highlight: `Code: <strong>${city.nearest_airport.code}</strong> · ${city.nearest_airport.distance_km}km away`
        },
        {
          icon: '🚂', mode: 'By Train',
          detail: `Nearest railhead: ${city.nearest_railhead.name}, ${city.nearest_railhead.distance_km}km away. ${city.nearest_railhead.note || ''}`,
          highlight: `Station: <strong>${city.nearest_railhead.name}</strong>`
        },
        {
          icon: '🚌', mode: 'By Road',
          detail: `${city.name} is ${city.distance_delhi_km}km from Delhi and ${city.distance_chandigarh_km}km from Chandigarh. Regular bus and taxi services available.`,
          highlight: `Delhi: <strong>${city.distance_delhi_km}km</strong> · Chandigarh: <strong>${city.distance_chandigarh_km}km</strong>`
        },
      ].map(t => `
    <div class="travel-card reveal">
      <span class="travel-icon">${t.icon}</span>
      <div class="travel-mode">${t.mode}</div>
      <p class="travel-detail">${t.detail}</p>
      <div class="travel-highlight">${t.highlight}</div>
    </div>`
      ).join('');
    }

    // ══════════════════════════════════════════════════
    // RENDER BUDGET
    // ══════════════════════════════════════════════════
    function renderBudget(city) {
      const b = city.budget_per_day_inr;
      document.getElementById('budgetGrid').innerHTML = [
        {
          tier: 'Budget', price: b.budget, key: 'budget', popular: false,
          features: ['Hostel or basic guesthouse', 'Local dhabas', 'Public bus transport', 'Self-guided sightseeing', 'Free attractions']
        },
        {
          tier: 'Mid Range', price: b.mid, key: 'mid', popular: true,
          features: ['Comfortable 3-star hotel', 'Restaurant dining', 'Shared taxis', 'Guided tours', 'Paid attractions']
        },
        {
          tier: 'Luxury', price: b.luxury, key: 'luxury', popular: false,
          features: ['5-star or heritage resort', 'Fine dining', 'Private car hire', 'Private guides', 'Spa & activities']
        },
      ].map(t => `
    <div class="budget-card ${t.key}">
      ${t.popular ? '<div class="budget-popular">Most Popular</div>' : ''}
      <div class="budget-tier">${t.tier}</div>
      <div class="budget-price">₹${t.price.toLocaleString('en-IN')}<span>/person</span></div>
      <div class="budget-per">estimated per day</div>
      <ul class="budget-features">${t.features.map(f => `<li class="budget-feature">${f}</li>`).join('')}</ul>
    </div>`
      ).join('');
    }

    // ══════════════════════════════════════════════════
    // RENDER CUISINE
    // ══════════════════════════════════════════════════
    function renderCuisine(city) {
      document.getElementById('cuisineList').innerHTML = city.cuisine.map(item =>
        `<div class="cuisine-pill">${item}</div>`
      ).join('');
    }

    // ══════════════════════════════════════════════════
    // RENDER FOOTER LINKS
    // ══════════════════════════════════════════════════
    function renderFooterLinks(allCities, currentId, stateId) {
      document.getElementById('footerCityLinks').innerHTML = allCities
        .filter(c => c.id !== currentId).slice(0, 6)
        .map(c => `<li><a href="/city?state=${stateId}&id=${c.id}">${c.name}</a></li>`)
        .join('');
    }

    // ══════════════════════════════════════════════════
    // SCROLL REVEAL
    // ══════════════════════════════════════════════════
    function initReveal() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    }

    // ══════════════════════════════════════════════════
    // NAV + PARALLAX
    // ══════════════════════════════════════════════════
    function initNav() {
      const nav = document.getElementById('mainNav');
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 60);
      }, { passive: true });
    }

    function initParallax() {
      const bg = document.getElementById('heroBg');
      window.addEventListener('scroll', () => {
        if (window.scrollY < window.innerHeight) {
          bg.style.transform = `scale(1) translateY(${window.scrollY * 0.25}px)`;
        }
      }, { passive: true });
    }

    // ══════════════════════════════════════════════════
    // MAIN
    // ══════════════════════════════════════════════════
    async function main() {
      const params = new URLSearchParams(window.location.search);
      const stateId = params.get('state') || STATE_REGISTRY[0].id;
      const cityId = params.get('id') || null;

      const stateMeta = STATE_REGISTRY.find(s => s.id === stateId);
      if (!stateMeta) {
        document.body.innerHTML = `<div class="error-state">
      <h1>State Not Found</h1>
      <p>No state "${stateId}" in registry.</p>
      <a href="/explore" class="btn-primary" style="display:inline-block;padding:14px 36px;background:#b68a3e;color:#fff;border-radius:40px;text-decoration:none;cursor:pointer;">Back to Home</a>
    </div>`;
        return;
      }

      const isUT = UT_IDS.has(stateId);
      const backUrl = `/explore/${stateId}`;

      // Update nav + breadcrumb
      document.getElementById('navBrand').href = backUrl;
      document.getElementById('navAllCities').href = backUrl;
      document.getElementById('bcState').href = backUrl;
      document.getElementById('bcState').textContent = stateMeta.name;
      if (isUT) {
        const chip = document.createElement('span');
        chip.className = 'ut-chip'; chip.textContent = 'UT';
        document.getElementById('bcState').after(chip);
      }
      document.getElementById('ctaStateBtn').href = backUrl;
      document.getElementById('ctaStateBtn').textContent = `Explore All ${stateMeta.name}`;
      document.getElementById('ctaSub').textContent = `Browse all destinations in ${stateMeta.name}.`;
      document.getElementById('footerTagline').textContent = `Your complete guide to ${stateMeta.name}`;

      try {
        const res = await fetch(stateMeta.file);
        if (!res.ok) throw new Error(`Could not load ${stateMeta.file}`);
        const data = await res.json();

        const city = data.cities.find(c => c.id === cityId) || data.cities[0];
        if (!city) {
          document.body.innerHTML = `<div class="error-state">
        <h1>City Not Found</h1>
        <p>No city "${cityId}" in ${stateMeta.name}.</p>
        <a href="${backUrl}">Back to ${stateMeta.name}</a>
      </div>`;
          return;
        }

        document.getElementById('bcCity').textContent = city.name;

        renderHero(city, stateMeta);
        renderAbout(city);
        renderHistory(city);
        renderPlaces(city);
        renderSeasons(city);
        renderTravel(city);
        renderBudget(city);
        renderCuisine(city);
        renderFooterLinks(data.cities, city.id, stateId);

        const weather = await fetchWeather(city);
        renderWeather(city, weather);

        initNav();
        initParallax();

        setTimeout(() => {
          document.getElementById('loader').classList.add('hidden');
          setTimeout(initReveal, 300);
        }, 1500);

      } catch (err) {
        console.error(err);
        document.getElementById('loader').innerHTML = `
      <div style="text-align:center;color:rgba(255,255,255,.6);padding:40px;">
        <div style="font-family:var(--serif);font-size:22px;color:#d4a555;margin-bottom:12px;">Something went wrong</div>
        <p>Could not load <strong>${stateMeta.file}</strong></p>
        <p style="font-size:12px;margin-top:6px;opacity:.4;">${err.message}</p>
        <a href="/explore" style="display:inline-block;margin-top:24px;padding:12px 28px;background:#b68a3e;color:#fff;border-radius:40px;text-decoration:none;font-size:13px;">Back to Home</a>
      </div>`;
      }
    }

    main();
  </script>
</body>

</html>