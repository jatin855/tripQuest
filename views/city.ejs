<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Loading… — Explore India</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --ink: #0f0e0c;
      --ink-2: #28261f;
      --ink-3: #6a6356;
      --fog: #f6f2ec;
      --fog-2: #ede8df;
      --fog-3: #ddd7cc;
      --gold: #b68a3e;
      --gold-light: #d4a555;
      --gold-pale: #f0e2c4;
      --gold-glow: rgba(184, 146, 74, .15);
      --ut-accent: #4a7fa0;
      --white: #fdfaf5;
      --shadow: 0 2px 20px rgba(15, 14, 12, .07);
      --shadow-lg: 0 12px 56px rgba(15, 14, 12, .16);
      --shadow-xl: 0 24px 80px rgba(15, 14, 12, .22);
      --radius: 12px;
      --radius-lg: 20px;
      --radius-xl: 28px;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'DM Sans', system-ui, sans-serif;
      --ease: cubic-bezier(.4, 0, .2, 1);
      --t: 0.28s cubic-bezier(.4, 0, .2, 1);
      --nav-h: 64px;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: var(--sans);
      background: var(--white);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      cursor: none;
      overflow-x: hidden;
    }

    /* ─── CUSTOM CURSOR ─── */
    #cursor-outer {
      position: fixed;
      width: 36px;
      height: 36px;
      border: 1.5px solid rgba(184, 138, 62, .5);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99999;
      transition: transform .12s ease, opacity .2s ease, width .2s ease, height .2s ease, border-color .2s ease;
      transform: translate(-50%, -50%);
    }

    #cursor-dot {
      position: fixed;
      width: 6px;
      height: 6px;
      background: var(--gold);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99999;
      transition: transform .06s ease;
      transform: translate(-50%, -50%);
    }

    body:has(a:hover) #cursor-outer,
    body:has(button:hover) #cursor-outer {
      width: 54px;
      height: 54px;
      border-color: var(--gold);
      background: rgba(184, 138, 62, .07);
    }

    /* ─── LOADER ─── */
    #loader {
      position: fixed;
      inset: 0;
      background: var(--ink);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 24px;
      z-index: 9999;
      transition: opacity .6s ease, visibility .6s ease;
    }

    #loader.hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .loader-logo {
      font-family: var(--serif);
      font-size: 30px;
      color: var(--gold-light);
      letter-spacing: 2px;
      font-weight: 400;
    }

    .loader-logo span {
      font-style: italic;
    }

    .loader-bar {
      width: 200px;
      height: 1px;
      background: rgba(255, 255, 255, .1);
      position: relative;
      overflow: hidden;
    }

    .loader-bar::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      transform: translateX(-100%);
      animation: loadBar 1.6s ease forwards;
    }

    @keyframes loadBar {
      to {
        transform: translateX(100%);
      }
    }

    .loader-city {
      font-size: 10px;
      color: rgba(255, 255, 255, .3);
      letter-spacing: 4px;
      text-transform: uppercase;
    }

    .loader-tagline {
      font-family: var(--serif);
      font-style: italic;
      font-size: 14px;
      color: rgba(255, 255, 255, .2);
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 200;
      height: var(--nav-h);
      padding: 0 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background var(--t), backdrop-filter var(--t), box-shadow var(--t);
    }

    nav.scrolled {
      background: rgba(253, 250, 245, .95);
      backdrop-filter: blur(16px);
      box-shadow: 0 1px 0 var(--fog-3);
    }

    .nav-brand {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 500;
      color: var(--white);
      text-decoration: none;
      letter-spacing: .3px;
      transition: color var(--t);
    }

    nav.scrolled .nav-brand {
      color: var(--ink);
    }

    .nav-brand em {
      color: var(--gold-light);
      font-style: italic;
    }

    nav.scrolled .nav-brand em {
      color: var(--gold);
    }

    .nav-links {
      display: flex;
      gap: 32px;
      align-items: center;
      list-style: none;
    }

    .nav-links a {
      font-size: 12.5px;
      font-weight: 500;
      color: rgba(255, 255, 255, .7);
      text-decoration: none;
      letter-spacing: .6px;
      transition: color var(--t);
    }

    nav.scrolled .nav-links a {
      color: var(--ink-3);
    }

    .nav-links a:hover {
      color: var(--gold-light) !important;
    }

    .nav-cta {
      padding: 9px 22px;
      background: var(--gold);
      color: var(--white) !important;
      border-radius: 40px;
      font-weight: 500 !important;
      letter-spacing: .5px;
      transition: all var(--t) !important;
    }

    .nav-cta:hover {
      background: var(--gold-light) !important;
      transform: translateY(-1px);
    }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: none;
      padding: 4px;
    }

    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--white);
      transition: background var(--t);
    }

    nav.scrolled .nav-hamburger span {
      background: var(--ink);
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 680px;
      display: grid;
      grid-template-rows: 1fr auto;
      overflow: hidden;
      padding-top: var(--nav-h);
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center 30%;
      transform: scale(1.06);
      transition: transform 10s cubic-bezier(.25, 0, .1, 1);
      will-change: transform;
    }

    .hero.loaded .hero-bg {
      transform: scale(1);
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to right, rgba(12, 10, 8, .85) 0%, rgba(12, 10, 8, .45) 55%, rgba(12, 10, 8, .2) 100%),
        linear-gradient(to top, rgba(12, 10, 8, .82) 0%, rgba(12, 10, 8, .3) 40%, transparent 70%);
    }

    .hero-grain {
      position: absolute;
      inset: 0;
      opacity: .3;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.06'/%3E%3C/svg%3E");
    }

    /* Breadcrumb inside hero top bar */
    .hero-topbar {
      position: absolute;
      top: var(--nav-h);
      left: 0;
      right: 0;
      z-index: 10;
      padding: 12px 52px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      color: rgba(255, 255, 255, .38);
      letter-spacing: .5px;
      border-bottom: 1px solid rgba(255, 255, 255, .07);
      background: rgba(12, 10, 8, .28);
      backdrop-filter: blur(4px);
    }

    .hero-topbar a {
      color: rgba(255, 255, 255, .38);
      text-decoration: none;
      transition: color var(--t);
    }

    .hero-topbar a:hover {
      color: var(--gold-light);
    }

    .hero-topbar .sep {
      color: rgba(255, 255, 255, .2);
    }

    .hero-topbar .current {
      color: var(--gold-light);
    }

    .ut-chip {
      display: inline-block;
      padding: 1px 8px;
      background: rgba(74, 127, 160, .22);
      border: 1px solid rgba(74, 127, 160, .35);
      border-radius: 10px;
      font-size: 9px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #9ec5dc;
      margin-left: 4px;
    }

    /* Hero content layout */
    .hero-body {
      position: relative;
      z-index: 5;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 52px 72px;
      padding-top: calc(var(--nav-h) + 40px + 40px);
      max-width: 820px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(184, 138, 62, .18);
      border: 1px solid rgba(184, 138, 62, .32);
      border-radius: 40px;
      padding: 6px 16px;
      font-size: 10.5px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold-light);
      margin-bottom: 22px;
      width: fit-content;
      opacity: 0;
      transform: translateY(14px);
      transition: opacity .7s ease .4s, transform .7s ease .4s;
    }

    .hero.loaded .hero-badge {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-badge.ut {
      background: rgba(74, 127, 160, .18);
      border-color: rgba(74, 127, 160, .32);
      color: #9ec5dc;
    }

    .hero-eyebrow {
      font-size: 10px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .38);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
      opacity: 0;
      transform: translateY(14px);
      transition: opacity .7s ease .25s, transform .7s ease .25s;
    }

    .hero.loaded .hero-eyebrow {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-eyebrow-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--gold);
    }

    .hero-title {
      font-family: var(--serif);
      font-size: clamp(54px, 9vw, 112px);
      font-weight: 400;
      line-height: .9;
      color: var(--white);
      margin-bottom: 20px;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity .85s ease .55s, transform .85s ease .55s;
    }

    .hero.loaded .hero-title {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-title em {
      font-style: italic;
      color: var(--gold-light);
      display: block;
      font-weight: 400;
    }

    .hero-title em.ut {
      color: #9ec5dc;
    }

    .hero-tagline {
      font-size: 15px;
      font-weight: 300;
      color: rgba(255, 255, 255, .48);
      letter-spacing: .2px;
      margin-bottom: 44px;
      max-width: 480px;
      line-height: 1.7;
      opacity: 0;
      transform: translateY(14px);
      transition: opacity .7s ease .72s, transform .7s ease .72s;
    }

    .hero.loaded .hero-tagline {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-stats {
      display: flex;
      gap: 0;
      opacity: 0;
      transform: translateY(14px);
      transition: opacity .7s ease .88s, transform .7s ease .88s;
    }

    .hero.loaded .hero-stats {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-stat {
      padding: 18px 28px;
      border-left: 1px solid rgba(255, 255, 255, .1);
    }

    .hero-stat:first-child {
      padding-left: 0;
      border-left: none;
    }

    .hero-stat strong {
      display: block;
      font-family: var(--serif);
      font-size: 26px;
      font-weight: 400;
      color: var(--white);
      line-height: 1;
      margin-bottom: 5px;
    }

    .hero-stat span {
      font-size: 9.5px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .35);
    }

    /* Weather widget — top-right of hero */
    .weather-widget {
      position: absolute;
      top: calc(var(--nav-h) + 40px + 52px);
      right: 52px;
      z-index: 10;
      background: rgba(12, 10, 8, .48);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: var(--radius-lg);
      padding: 20px 24px;
      min-width: 196px;
      opacity: 0;
      transform: translateY(-8px);
      transition: opacity .7s ease 1.1s, transform .7s ease 1.1s;
    }

    .hero.loaded .weather-widget {
      opacity: 1;
      transform: translateY(0);
    }

    .w-city-name {
      font-size: 9.5px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .32);
      margin-bottom: 12px;
    }

    .w-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 6px;
    }

    .w-temp {
      font-family: var(--serif);
      font-size: 48px;
      font-weight: 400;
      color: var(--white);
      line-height: 1;
    }

    .w-icon {
      font-size: 30px;
      margin-top: 4px;
    }

    .w-cond {
      font-size: 12px;
      color: rgba(255, 255, 255, .55);
      margin-bottom: 14px;
      text-transform: capitalize;
    }

    .w-details {
      display: flex;
      gap: 16px;
      padding-top: 14px;
      border-top: 1px solid rgba(255, 255, 255, .08);
    }

    .w-detail {
      font-size: 10px;
      color: rgba(255, 255, 255, .38);
    }

    .w-detail strong {
      display: block;
      color: rgba(255, 255, 255, .7);
      font-size: 12px;
      font-weight: 500;
      margin-bottom: 2px;
    }

    .w-source {
      font-size: 9px;
      color: rgba(255, 255, 255, .2);
      margin-top: 10px;
    }

    .live-dot {
      display: inline-block;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #4ade80;
      margin-right: 4px;
      animation: pulse 2s ease infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1
      }

      50% {
        opacity: .3
      }
    }

    /* Hero scroll indicator */
    .hero-scroll {
      position: absolute;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0;
      transition: opacity .7s ease 1.4s;
    }

    .hero.loaded .hero-scroll {
      opacity: 1;
    }

    .hero-scroll span {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .28);
    }

    .scroll-line {
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, rgba(255, 255, 255, .35), transparent);
      animation: scrollLine 2s ease infinite;
    }

    @keyframes scrollLine {
      0% {
        transform: scaleY(0);
        transform-origin: top;
        opacity: 1;
      }

      50% {
        transform: scaleY(1);
        transform-origin: top;
        opacity: 1;
      }

      51% {
        transform: scaleY(1);
        transform-origin: bottom;
      }

      100% {
        transform: scaleY(0);
        transform-origin: bottom;
        opacity: 0;
      }
    }

    /* ─── INFO BAR ─── */
    .info-bar {
      background: var(--ink-2);
      padding: 0 52px;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      border-bottom: 1px solid rgba(255, 255, 255, .05);
    }

    .ib-item {
      padding: 22px 0;
      border-right: 1px solid rgba(255, 255, 255, .05);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .ib-item:last-child {
      border-right: none;
    }

    .ib-item:not(:first-child) {
      padding-left: 28px;
    }

    .ib-label {
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .24);
    }

    .ib-value {
      font-family: var(--serif);
      font-size: 16px;
      font-weight: 400;
      color: var(--white);
      line-height: 1.25;
    }

    .ib-sub {
      font-size: 10px;
      color: rgba(255, 255, 255, .28);
    }

    /* ─── SECTIONS ─── */
    .section {
      padding: 96px 52px;
    }

    .section-sm {
      padding: 72px 52px;
    }

    .section-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 10px;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
    }

    .section-eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--gold);
      opacity: .5;
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(30px, 4vw, 50px);
      font-weight: 400;
      line-height: 1.12;
      color: var(--ink);
      margin-bottom: 20px;
    }

    .section-title em {
      font-style: italic;
      color: var(--gold);
    }

    .section-lead {
      font-size: 15px;
      line-height: 1.9;
      color: var(--ink-3);
      font-weight: 300;
      max-width: 620px;
    }

    /* ─── ABOUT ─── */
    .about-section {
      background: var(--white);
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 80px;
      align-items: start;
      margin-top: 52px;
    }

    .about-text p {
      font-size: 15.5px;
      line-height: 1.95;
      color: var(--ink-2);
      font-weight: 300;
      margin-bottom: 20px;
    }

    .facts-card {
      background: var(--fog);
      border-radius: var(--radius-xl);
      padding: 36px;
      position: sticky;
      top: calc(var(--nav-h) + 20px);
      border: 1px solid var(--fog-3);
    }

    .facts-card-title {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 22px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--fog-3);
    }

    .fact-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 11px 0;
      border-bottom: 1px solid var(--fog-3);
      gap: 12px;
    }

    .fact-row:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .fact-key {
      font-size: 9.5px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--ink-3);
      flex-shrink: 0;
    }

    .fact-val {
      font-size: 12.5px;
      font-weight: 500;
      color: var(--ink);
      text-align: right;
      max-width: 180px;
      line-height: 1.4;
    }

    .best-time-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: var(--gold-glow);
      border: 1px solid rgba(184, 138, 62, .2);
      border-radius: 20px;
      padding: 7px 16px;
      font-size: 12px;
      color: var(--gold);
      font-weight: 500;
      margin-top: 18px;
      width: 100%;
    }

    /* ─── HISTORY ─── */
    .history-section {
      background: var(--fog);
    }

    .history-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      margin-top: 0;
    }

    .history-img-wrap {
      position: relative;
    }

    .history-img {
      width: 100%;
      height: 440px;
      object-fit: cover;
      border-radius: var(--radius-xl);
      filter: sepia(10%) brightness(.9) contrast(1.04);
      display: block;
    }

    .history-img-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 56px 22px 20px;
      background: linear-gradient(to top, rgba(12, 10, 8, .65), transparent);
      border-radius: 0 0 var(--radius-xl) var(--radius-xl);
      font-size: 11px;
      font-style: italic;
      color: rgba(255, 255, 255, .5);
    }

    .history-accent {
      border-left: 2px solid var(--gold);
      padding: 16px 22px;
      margin: 26px 0;
      background: rgba(184, 138, 62, .04);
      border-radius: 0 10px 10px 0;
    }

    .history-accent p {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      font-style: italic;
      color: var(--ink-2);
      line-height: 1.65;
    }

    .history-text p {
      font-size: 14.5px;
      line-height: 1.9;
      color: var(--ink-3);
      font-weight: 300;
      margin-bottom: 16px;
    }

    /* ─── PLACES ─── */
    .places-section {
      background: var(--white);
    }

    .places-header {
      margin-bottom: 44px;
    }

    .places-header-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 24px;
    }

    .filter-bar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .filter-btn {
      padding: 8px 20px;
      border-radius: 40px;
      border: 1px solid var(--fog-3);
      background: transparent;
      color: var(--ink-3);
      font-size: 12px;
      font-weight: 500;
      cursor: none;
      font-family: var(--sans);
      transition: all var(--t);
      letter-spacing: .4px;
    }

    .filter-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    .filter-btn.active {
      background: var(--gold);
      border-color: var(--gold);
      color: var(--white);
    }

    .ut-mode .filter-btn.active {
      background: var(--ut-accent);
      border-color: var(--ut-accent);
    }

    .places-search-wrap {
      position: relative;
    }

    .places-search-input {
      width: 100%;
      padding: 13px 48px 13px 20px;
      border: 1.5px solid var(--fog-3);
      border-radius: 40px;
      font-family: var(--sans);
      font-size: 13.5px;
      color: var(--ink);
      background: var(--fog);
      outline: none;
      transition: all var(--t);
    }

    .places-search-input:focus {
      border-color: var(--gold);
      background: var(--white);
      box-shadow: 0 0 0 4px rgba(184, 138, 62, .08);
    }

    .places-search-icon {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 15px;
      pointer-events: none;
      color: var(--ink-3);
    }

    .places-search-count {
      font-size: 12px;
      color: var(--ink-3);
      margin-top: 10px;
    }

    .places-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .place-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      overflow: hidden;
      border: 1px solid var(--fog-3);
      box-shadow: var(--shadow);
      transition: transform .32s ease, box-shadow .32s ease, border-color .32s ease;
      cursor: none;
    }

    .place-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
      border-color: rgba(184, 138, 62, .22);
    }

    .place-card.featured {
      grid-column: span 2;
    }

    .place-card.hidden-card {
      display: none;
    }

    /* ── Hidden Gem card ── */
    .place-card.gem-card {
      border-color: rgba(196,154,60,.35);
      background: linear-gradient(160deg, #fffdf6 0%, #fef9ec 100%);
    }
    .place-card.gem-card:hover {
      border-color: rgba(196,154,60,.65);
      box-shadow: 0 12px 40px rgba(196,154,60,.18);
    }
    .gem-badge {
      display: inline-flex; align-items: center; gap: 5px;
      background: linear-gradient(135deg,#c49a3c,#ddb95a);
      color: #fff; font-size: 0.65rem; font-weight: 700;
      letter-spacing: .06em; text-transform: uppercase;
      padding: 3px 10px; border-radius: 20px;
    }
    .filter-btn.gem-btn {
      background: linear-gradient(135deg,#c49a3c,#ddb95a);
      color: #fff; border-color: transparent;
    }
    .filter-btn.gem-btn:hover, .filter-btn.gem-btn.active {
      background: linear-gradient(135deg,#b38630,#c49a3c);
      color: #fff;
    }

    .card-img-wrap {
      overflow: hidden;
      position: relative;
    }

    .card-img {
      width: 100%;
      height: 218px;
      object-fit: cover;
      display: block;
      transition: transform .55s ease;
    }

    .place-card.featured .card-img {
      height: 300px;
    }

    .place-card:hover .card-img {
      transform: scale(1.06);
    }

    .card-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(12, 10, 8, .55) 0%, transparent 55%);
    }

    .card-badges {
      position: absolute;
      bottom: 12px;
      left: 12px;
      right: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .card-cat-badge {
      background: rgba(12, 10, 8, .6);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 4px 12px;
      font-size: 9.5px;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .8);
    }

    .card-rating {
      display: flex;
      align-items: center;
      gap: 4px;
      background: rgba(12, 10, 8, .6);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 600;
      color: var(--white);
    }

    .card-rating .star {
      color: #f59e0b;
      font-size: 10px;
    }

    .card-body {
      padding: 22px 22px 20px;
    }

    .card-title {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 8px;
      line-height: 1.2;
    }

    .place-card.featured .card-title {
      font-size: 24px;
    }

    .card-desc {
      font-size: 13px;
      line-height: 1.8;
      color: var(--ink-3);
      font-weight: 300;
      margin-bottom: 16px;
    }

    .card-meta {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      padding-top: 14px;
      border-top: 1px solid var(--fog-3);
    }

    .card-meta-item {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: var(--ink-3);
    }

    .card-tip {
      margin-top: 12px;
      padding: 10px 14px;
      background: var(--fog);
      border-radius: 10px;
      font-size: 11.5px;
      color: var(--ink-3);
      line-height: 1.65;
    }

    .card-tip strong {
      color: var(--gold);
      font-weight: 600;
    }

    .no-places {
      grid-column: 1/-1;
      text-align: center;
      padding: 64px 24px;
    }

    .no-places p {
      font-size: 14px;
      color: var(--ink-3);
    }

    /* ─── SEASONS ─── */
    .time-section {
      background: var(--ink);
    }

    .time-section .section-eyebrow {
      color: rgba(184, 138, 62, .7);
    }

    .time-section .section-eyebrow::before {
      background: rgba(184, 138, 62, .4);
      opacity: 1;
    }

    .time-section .section-title {
      color: var(--white);
    }

    .time-section .section-title em {
      color: var(--gold-light);
    }

    .seasons-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-top: 52px;
    }

    .season-card {
      border-radius: var(--radius-lg);
      padding: 30px 24px;
      border: 1px solid rgba(255, 255, 255, .07);
      background: rgba(255, 255, 255, .03);
      position: relative;
      overflow: hidden;
      transition: border-color .3s, background .3s;
    }

    .season-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 80% at 50% 100%, rgba(184, 138, 62, .08), transparent);
      opacity: 0;
      transition: opacity .3s;
    }

    .season-card:hover::before {
      opacity: 1;
    }

    .season-card:hover {
      border-color: rgba(184, 138, 62, .2);
    }

    .season-card.recommended {
      border-color: rgba(184, 138, 62, .22);
      background: rgba(184, 138, 62, .06);
    }

    .season-card.recommended::before {
      opacity: 1;
    }

    .season-rec-tag {
      position: absolute;
      top: 14px;
      right: 14px;
      font-size: 9px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--gold);
      background: rgba(184, 138, 62, .12);
      border: 1px solid rgba(184, 138, 62, .22);
      border-radius: 20px;
      padding: 3px 10px;
    }

    .season-icon {
      font-size: 30px;
      display: block;
      margin-bottom: 16px;
    }

    .season-name {
      font-family: var(--serif);
      font-size: 21px;
      font-weight: 400;
      color: var(--white);
      margin-bottom: 4px;
    }

    .season-months {
      font-size: 10.5px;
      letter-spacing: 1px;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .season-temp {
      font-size: 11.5px;
      color: rgba(255, 255, 255, .4);
      margin-bottom: 12px;
    }

    .season-desc {
      font-size: 12.5px;
      line-height: 1.75;
      color: rgba(255, 255, 255, .4);
      font-weight: 300;
    }

    /* ─── TRAVEL ─── */
    .travel-section {
      background: var(--fog);
    }

    .travel-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 52px;
    }

    .travel-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 34px 28px;
      border: 1px solid var(--fog-3);
      box-shadow: var(--shadow);
      transition: transform .28s ease, box-shadow .28s ease;
    }

    .travel-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }

    .travel-icon {
      font-size: 34px;
      display: block;
      margin-bottom: 18px;
    }

    .travel-mode {
      font-family: var(--serif);
      font-size: 21px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 12px;
    }

    .travel-detail {
      font-size: 13.5px;
      line-height: 1.85;
      color: var(--ink-3);
      font-weight: 300;
    }

    .travel-highlight {
      margin-top: 16px;
      padding: 12px 16px;
      background: var(--gold-pale);
      border-radius: 10px;
      font-size: 12.5px;
      color: var(--ink-2);
    }

    .travel-highlight strong {
      color: var(--gold);
    }

    /* ─── BUDGET ─── */
    .budget-section {
      background: var(--white);
    }

    .budget-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 52px;
    }

    .budget-card {
      border-radius: var(--radius-lg);
      padding: 36px 28px;
      border: 1px solid var(--fog-3);
      background: var(--white);
      position: relative;
      transition: transform .28s ease, box-shadow .28s ease;
    }

    .budget-card.mid {
      border-color: var(--gold);
      box-shadow: 0 0 0 1px var(--gold), var(--shadow);
    }

    .budget-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }

    .budget-tier {
      font-size: 9.5px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--ink-3);
      margin-bottom: 10px;
    }

    .budget-card.mid .budget-tier {
      color: var(--gold);
    }

    .budget-price {
      font-family: var(--serif);
      font-size: 40px;
      font-weight: 400;
      color: var(--ink);
      line-height: 1;
      margin-bottom: 6px;
    }

    .budget-price span {
      font-size: 17px;
      color: var(--ink-3);
    }

    .budget-per {
      font-size: 11px;
      color: var(--ink-3);
      margin-bottom: 22px;
    }

    .budget-features {
      list-style: none;
    }

    .budget-feature {
      display: flex;
      align-items: flex-start;
      gap: 9px;
      font-size: 13px;
      color: var(--ink-3);
      font-weight: 300;
      padding: 8px 0;
      border-bottom: 1px solid var(--fog-3);
    }

    .budget-feature:last-child {
      border-bottom: none;
    }

    .budget-feature::before {
      content: '✓';
      color: var(--gold);
      font-weight: 600;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .budget-popular {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--gold);
      color: var(--white);
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 4px 16px;
      border-radius: 20px;
      white-space: nowrap;
    }

    /* ─── CUISINE ─── */
    .cuisine-section {
      background: var(--fog);
    }

    .cuisine-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 40px;
    }

    .cuisine-pill {
      padding: 11px 24px;
      background: var(--white);
      border: 1px solid var(--fog-3);
      border-radius: 40px;
      font-size: 14px;
      color: var(--ink-2);
      box-shadow: var(--shadow);
      transition: all var(--t);
    }

    .cuisine-pill:hover {
      border-color: var(--gold);
      background: var(--gold-pale);
      color: var(--ink);
      transform: translateY(-2px);
    }

    /* ─── CTA ─── */
    .cta-section {
      background: var(--ink);
      padding: 104px 52px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 70% at 50% 110%, rgba(184, 138, 62, .12), transparent);
    }

    .cta-section::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(184, 138, 62, .3), transparent);
    }

    .cta-inner {
      position: relative;
      z-index: 1;
      max-width: 560px;
      margin: 0 auto;
    }

    .cta-title {
      font-family: var(--serif);
      font-size: clamp(34px, 4.8vw, 54px);
      font-weight: 400;
      line-height: 1.12;
      color: var(--white);
      margin-bottom: 16px;
    }

    .cta-title em {
      font-style: italic;
      color: var(--gold-light);
    }

    .cta-sub {
      font-size: 14px;
      color: rgba(255, 255, 255, .35);
      font-weight: 300;
      margin-bottom: 40px;
      line-height: 1.8;
    }

    .cta-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      padding: 14px 36px;
      background: var(--gold);
      color: var(--white);
      border-radius: 40px;
      font-size: 13px;
      font-weight: 500;
      border: none;
      cursor: none;
      font-family: var(--sans);
      letter-spacing: .4px;
      transition: all var(--t);
      text-decoration: none;
      display: inline-block;
    }

    .btn-primary:hover {
      background: var(--gold-light);
      color: var(--ink);
      transform: translateY(-2px);
    }

    .btn-outline {
      padding: 14px 36px;
      background: transparent;
      color: rgba(255, 255, 255, .6);
      border-radius: 40px;
      font-size: 13px;
      font-weight: 500;
      border: 1px solid rgba(255, 255, 255, .15);
      cursor: none;
      font-family: var(--sans);
      letter-spacing: .4px;
      transition: all var(--t);
      text-decoration: none;
      display: inline-block;
    }

    .btn-outline:hover {
      border-color: var(--gold);
      color: var(--gold);
      transform: translateY(-2px);
    }

    /* ─── FOOTER ─── */
    footer {
      background: #080705;
      padding: 64px 52px 40px;
    }

    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 48px;
      padding-bottom: 48px;
      border-bottom: 1px solid rgba(255, 255, 255, .06);
      flex-wrap: wrap;
      gap: 40px;
    }

    .footer-brand {
      font-family: var(--serif);
      font-size: 26px;
      font-weight: 400;
      color: var(--white);
    }

    .footer-brand em {
      color: var(--gold);
      font-style: italic;
    }

    .footer-tagline {
      font-size: 12px;
      color: rgba(255, 255, 255, .25);
      margin-top: 7px;
      font-weight: 300;
    }

    .footer-nav-groups {
      display: flex;
      gap: 64px;
      flex-wrap: wrap;
    }

    .footer-nav-group h4 {
      font-size: 9.5px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .24);
      margin-bottom: 16px;
    }

    .footer-nav-group ul {
      list-style: none;
    }

    .footer-nav-group li {
      margin-bottom: 10px;
    }

    .footer-nav-group a {
      font-size: 13px;
      color: rgba(255, 255, 255, .4);
      text-decoration: none;
      font-weight: 300;
      transition: color var(--t);
    }

    .footer-nav-group a:hover {
      color: var(--gold-light);
    }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .footer-copy {
      font-size: 11px;
      color: rgba(255, 255, 255, .15);
    }

    .api-note {
      font-size: 10px;
      color: rgba(255, 255, 255, .18);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* ─── REVEAL ANIMATION ─── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .75s ease, transform .75s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── ERROR STATE ─── */
    .error-state {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px;
      background: var(--fog);
    }

    .error-state h1 {
      font-family: var(--serif);
      font-size: 44px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 12px;
    }

    .error-state p {
      font-size: 14px;
      color: var(--ink-3);
      margin-bottom: 28px;
      max-width: 380px;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1140px) {
      .about-grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }

      .facts-card {
        position: static;
      }

      .history-grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }

      .history-img-wrap {
        order: -1;
      }

      .places-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .place-card.featured {
        grid-column: span 2;
      }

      .seasons-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .info-bar {
        grid-template-columns: repeat(3, 1fr);
        padding: 0 40px;
      }

      .section,
      .section-sm {
        padding: 80px 40px;
      }

      nav {
        padding: 0 40px;
      }

      .hero-topbar {
        padding: 12px 40px;
      }

      .hero-body {
        padding: 0 40px 64px;
        padding-top: calc(var(--nav-h) + 40px + 40px);
      }

      .weather-widget {
        right: 40px;
        top: calc(var(--nav-h) + 40px + 44px);
      }
    }

    @media (max-width: 860px) {
      .nav-links {
        display: none;
      }

      .nav-hamburger {
        display: flex;
      }

      .weather-widget {
        position: static;
        opacity: 1 !important;
        transform: none !important;
        margin: 0 20px 28px;
        width: calc(100% - 40px);
        max-width: 300px;
        background: rgba(12, 10, 8, .52);
      }

      .hero-body {
        padding: 0 20px 48px;
        padding-top: calc(var(--nav-h) + 36px + 48px);
      }

      .hero-topbar {
        padding: 10px 20px;
      }

      .hero-stats {
        gap: 0;
        flex-wrap: wrap;
      }

      .hero-stat {
        padding: 14px 20px;
      }

      .info-bar {
        padding: 0 20px;
        grid-template-columns: repeat(2, 1fr);
      }

      .section,
      .section-sm {
        padding: 64px 20px;
      }

      nav {
        padding: 0 20px;
      }

      .hero-title {
        font-size: clamp(44px, 12vw, 72px);
      }

      .places-grid,
      .budget-grid,
      .travel-grid,
      .seasons-grid {
        grid-template-columns: 1fr;
      }

      .place-card.featured {
        grid-column: span 1;
      }

      .place-card.featured .card-img {
        height: 218px;
      }

      footer {
        padding: 48px 20px 32px;
      }

      .footer-top {
        flex-direction: column;
      }

      .cta-section {
        padding: 80px 20px;
      }
    }

    @media (max-width: 480px) {
      .hero-stat {
        padding: 12px 16px;
      }

      .hero-stat:first-child {
        padding-left: 0;
      }

      .info-bar {
        grid-template-columns: 1fr 1fr;
      }

      .budget-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <!-- CUSTOM CURSOR -->
  <div id="cursor-outer"></div>
  <div id="cursor-dot"></div>

  <!-- LOADER -->
  <div id="loader">
    <div class="loader-logo">Explore <em>India</em></div>
    <div class="loader-bar"></div>
    <div class="loader-city" id="loaderCityName">Loading…</div>
    <div class="loader-tagline">Discovering your destination</div>
  </div>

  <!-- NAV -->
  <nav id="mainNav">
    <a href="/explore" class="nav-brand" id="navBrand">Explore <em>India</em></a>
    <ul class="nav-links">
      <li><a href="/home">Home</a></li>
      <li><a href="/explore" id="navAllCities">All Cities</a></li>
      <li><a href="#places">Places</a></li>
