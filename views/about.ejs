<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About – TripQuest</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    body { font-family:'Nunito',sans-serif; background:#f7f8fa; color:#1a1a1a; overflow-x:hidden; }

    .dot-bg { position:fixed; inset:0; z-index:-1; background-color:#f0f2f5; background-image:radial-gradient(circle,#c8cdd6 1px,transparent 1px); background-size:24px 24px; }

    .navbar { position:sticky; top:0; z-index:100; background:rgba(255,255,255,0.92); backdrop-filter:blur(12px); border-bottom:1px solid rgba(0,0,0,0.07); box-shadow:0 1px 12px rgba(0,0,0,0.06); }

    .green-text { background:linear-gradient(135deg,#00AA6C 0%,#34E0A1 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

    .nav-link { color:#4a4a4a; cursor:pointer; transition:color 0.2s; position:relative; }
    .nav-link:hover { color:#00AA6C; }
    .nav-link.active { color:#00AA6C; }
    .nav-link.active::after { content:''; position:absolute; bottom:-4px; left:0; right:0; height:2px; background:linear-gradient(90deg,#00AA6C,#34E0A1); border-radius:2px; }

    .avatar { width:38px; height:38px; background:linear-gradient(135deg,#34E0A1,#00AA6C); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:900; font-size:0.95rem; color:white; cursor:pointer; text-decoration:none; transition:all 0.2s; box-shadow:0 2px 8px rgba(0,170,108,0.35); flex-shrink:0; }
    .avatar:hover { transform:scale(1.08); }

    .greeting-pill { display:inline-flex; align-items:center; gap:6px; background:rgba(52,224,161,0.1); border:1.5px solid rgba(0,170,108,0.2); border-radius:100px; padding:5px 14px; font-size:0.83rem; font-weight:700; color:#00AA6C; }

    .btn-profile { display:inline-flex; align-items:center; gap:6px; background:white; border:1.5px solid rgba(0,170,108,0.35); color:#00AA6C; font-weight:800; font-family:'Nunito',sans-serif; font-size:0.83rem; border-radius:10px; padding:7px 16px; cursor:pointer; text-decoration:none; transition:all 0.22s; }
    .btn-profile:hover { background:rgba(0,170,108,0.07); border-color:#00AA6C; transform:translateY(-1px); }

    .btn-logout { font-size:0.82rem; font-weight:700; color:#8a8a8a; text-decoration:none; padding:6px 14px; border:1.5px solid #d4d4d4; border-radius:8px; transition:all 0.2s; font-family:'Nunito',sans-serif; background:transparent; cursor:pointer; }
    .btn-logout:hover { border-color:#e05252; color:#e05252; }

    .btn-green { background:#34E0A1; color:#1a1a1a; font-weight:800; font-family:'Nunito',sans-serif; border-radius:10px; transition:all 0.22s; box-shadow:0 4px 14px rgba(52,224,161,0.38); border:none; cursor:pointer; }
    .btn-green:hover { background:#28d494; transform:translateY(-1px); box-shadow:0 6px 20px rgba(52,224,161,0.48); }

    /* Hero */
    .about-hero { background:linear-gradient(160deg,#ffffff 0%,#f0fdf8 50%,#e6fdf5 100%); border-bottom:1px solid rgba(52,224,161,0.15); padding:80px 24px 60px; text-align:center; }

    /* Cards */
    .about-card { background:white; border:1.5px solid rgba(0,0,0,0.07); border-radius:16px; padding:2rem; box-shadow:0 2px 8px rgba(0,0,0,0.04); transition:all 0.3s cubic-bezier(0.4,0,0.2,1); }
    .about-card:hover { transform:translateY(-6px); box-shadow:0 12px 32px rgba(0,170,108,0.12); border-color:rgba(0,170,108,0.25); }

    .icon-box { width:54px; height:54px; background:linear-gradient(135deg,rgba(52,224,161,0.15),rgba(0,170,108,0.1)); border:1.5px solid rgba(0,170,108,0.2); border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.6rem; transition:0.25s; margin-bottom:1rem; }
    .about-card:hover .icon-box { transform:scale(1.1) rotate(4deg); border-color:rgba(0,170,108,0.4); }

    .stat-card { background:white; border:1.5px solid rgba(0,0,0,0.07); border-radius:14px; padding:1.75rem 1.5rem; text-align:center; box-shadow:0 2px 8px rgba(0,0,0,0.04); transition:all 0.25s; }
    .stat-card:hover { transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,170,108,0.12); }

    /* Team */
    .team-card { background:white; border:1.5px solid rgba(0,0,0,0.07); border-radius:16px; padding:2rem; text-align:center; box-shadow:0 2px 8px rgba(0,0,0,0.04); transition:all 0.3s; }
    .team-card:hover { transform:translateY(-6px); box-shadow:0 12px 32px rgba(0,170,108,0.12); border-color:rgba(0,170,108,0.25); }
    .team-avatar { width:80px; height:80px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:2rem; color:white; font-weight:900; margin:0 auto 16px; box-shadow:0 4px 16px rgba(0,170,108,0.3); }

    /* Timeline */
    .timeline-item { position:relative; padding-left:36px; padding-bottom:36px; border-left:2px solid rgba(0,170,108,0.2); }
    .timeline-item:last-child { border-left-color:transparent; padding-bottom:0; }
    .timeline-dot { position:absolute; left:-8px; top:2px; width:14px; height:14px; border-radius:50%; background:linear-gradient(135deg,#00AA6C,#34E0A1); box-shadow:0 2px 8px rgba(0,170,108,0.35); }

    footer { background:#1a1a1a; color:#9a9a9a; }
  </style>
</head>

<body>
  <!-- DOT BG -->
  <div class="dot-bg"></div>

  <!-- ══════════ NAVBAR ══════════ -->
  <header class="navbar">
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/home" class="flex items-center gap-2 no-underline">
        <div style="width:36px;height:36px;background:#34E0A1;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;box-shadow:0 2px 8px rgba(52,224,161,.35)">🦉</div>
        <span style="font-size:1.2rem;font-weight:900;color:#1a1a1a;letter-spacing:-0.02em">Trip<span style="color:#00AA6C">Advisor</span></span>
      </a>

      <ul class="hidden md:flex gap-7 text-sm list-none" style="font-weight:700">
        <li class="nav-link" onclick="window.location.href='/home'">Home</li>
        <li class="nav-link" onclick="window.location.href='/explore'">Explore</li>
        <li class="nav-link" onclick="window.location.href='/experiences'">Experiences</li>
        <li class="nav-link" onclick="window.location.href='/reviews'">Reviews</li>
        <li class="nav-link active" onclick="window.location.href='/about'">About</li>
      </ul>

      <div class="flex items-center gap-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <span class="greeting-pill hidden md:inline-flex">👋 Hey, <%= user.name.split(' ')[0] %>!</span>
          <a href="/profile" class="avatar" title="Go to Profile"><%= user.name.charAt(0).toUpperCase() %></a>
          <a href="/profile" class="btn-profile hidden md:inline-flex">👤 Profile</a>
          <a href="/logout" class="btn-logout">Logout</a>
        <% } else { %>
          <a href="/login" style="font-size:0.85rem;font-weight:800;color:#00AA6C;text-decoration:none">Sign In</a>
          <a href="/register"><button class="btn-green px-5 py-2 text-sm">Get Started</button></a>
        <% } %>
      </div>
    </nav>
  </header>


  <!-- ══════════ HERO ══════════ -->
  <section class="about-hero">
    <div class="max-w-3xl mx-auto">
      <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(52,224,161,0.1);border:1.5px solid rgba(0,170,108,0.2);border-radius:100px;padding:5px 16px;font-size:0.78rem;font-weight:800;color:#00AA6C;margin-bottom:18px;letter-spacing:0.04em">
        🌍 OUR STORY
      </div>
      <h1 style="font-size:clamp(2.2rem,5vw,3.5rem);font-weight:900;line-height:1.15;letter-spacing:-0.03em;color:#1a1a1a;margin-bottom:20px">
        Connecting Travelers with <span class="green-text">Authentic Culture</span>
      </h1>
      <p style="font-size:1.05rem;color:#8a8a8a;max-width:560px;margin:0 auto;line-height:1.8;font-weight:500">
        We believe travel is more than sightseeing — it's about experiencing the soul of a place through its people, traditions, and stories.
      </p>
    </div>
  </section>


  <!-- ══════════ LIVE STATS ══════════ -->
  <section class="py-14 px-6" style="margin-top:-30px;position:relative;z-index:2">
    <div class="max-w-4xl mx-auto grid grid-cols-3 gap-5">
      <div class="stat-card">
        <div class="text-3xl font-black green-text"><%= (typeof stats !== 'undefined') ? stats.totalUsers : 0 %></div>
        <div style="font-size:0.82rem;color:#8a8a8a;margin-top:6px;font-weight:600">Registered Travelers</div>
      </div>
      <div class="stat-card">
        <div class="text-3xl font-black green-text"><%= (typeof stats !== 'undefined') ? stats.totalReviews : 0 %></div>
        <div style="font-size:0.82rem;color:#8a8a8a;margin-top:6px;font-weight:600">Reviews Written</div>
      </div>
      <div class="stat-card">
        <div class="text-3xl font-black green-text"><%= (typeof stats !== 'undefined') ? stats.totalExperiences : 0 %></div>
        <div style="font-size:0.82rem;color:#8a8a8a;margin-top:6px;font-weight:600">Experiences Live</div>
      </div>
    </div>
  </section>


  <!-- ══════════ MISSION ══════════ -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 style="font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:#1a1a1a;letter-spacing:-0.02em;margin-bottom:10px">
          What Drives <span class="green-text">Us</span>
        </h2>
        <p style="color:#8a8a8a;max-width:520px;margin:0 auto;font-size:0.95rem;line-height:1.7;font-weight:500">
          Our core values shape every experience on the platform.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-7">
        <div class="about-card">
          <div class="icon-box">🌏</div>
          <h3 style="font-size:1.1rem;font-weight:800;color:#1a1a1a;margin-bottom:8px">Cultural Immersion</h3>
          <p style="color:#8a8a8a;font-size:0.87rem;line-height:1.7;font-weight:500">We go beyond surface-level tourism to connect you with the living heritage, artisan traditions, and local stories of every destination.</p>
        </div>
        <div class="about-card">
          <div class="icon-box">🤝</div>
          <h3 style="font-size:1.1rem;font-weight:800;color:#1a1a1a;margin-bottom:8px">Community First</h3>
          <p style="color:#8a8a8a;font-size:0.87rem;line-height:1.7;font-weight:500">Every review, experience, and recommendation is powered by our community of travelers and local hosts who share real insights.</p>
        </div>
        <div class="about-card">
          <div class="icon-box">💡</div>
          <h3 style="font-size:1.1rem;font-weight:800;color:#1a1a1a;margin-bottom:8px">Smart Discovery</h3>
          <p style="color:#8a8a8a;font-size:0.87rem;line-height:1.7;font-weight:500">AI-powered recommendations, curated itineraries, and smart search help you find exactly the experience you're looking for.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════ OUR JOURNEY / TIMELINE ══════════ -->
  <section style="background:linear-gradient(160deg,#f0fdf8,#ffffff,#f0fdf8);padding:80px 24px">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14">
        <h2 style="font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:#1a1a1a;letter-spacing:-0.02em;margin-bottom:10px">
          Our <span class="green-text">Journey</span>
        </h2>
        <p style="color:#8a8a8a;font-size:0.95rem;font-weight:500">From a passion project to a growing travel community.</p>
      </div>

      <div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div style="font-size:0.75rem;font-weight:800;color:#00AA6C;letter-spacing:0.04em;margin-bottom:6px">2024 — THE BEGINNING</div>
          <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:6px">Idea Takes Shape</h3>
          <p style="color:#8a8a8a;font-size:0.87rem;line-height:1.7;font-weight:500">Started as a college project to help travelers discover India's hidden cultural gems beyond the usual tourist spots.</p>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div style="font-size:0.75rem;font-weight:800;color:#00AA6C;letter-spacing:0.04em;margin-bottom:6px">2025 — BUILDING</div>
          <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:6px">Platform Launch</h3>
          <p style="color:#8a8a8a;font-size:0.87rem;line-height:1.7;font-weight:500">Built the explore engine with 150+ destinations, integrated AI chat assistant, and launched the local host experience program.</p>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div style="font-size:0.75rem;font-weight:800;color:#00AA6C;letter-spacing:0.04em;margin-bottom:6px">2026 — GROWING</div>
          <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:6px">Community & Reviews</h3>
          <p style="color:#8a8a8a;font-size:0.87rem;line-height:1.7;font-weight:500">Launched the reviews system, community profiles, and smart search — letting travelers share and discover authentic experiences together.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════ TEAM ══════════ -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 style="font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:#1a1a1a;letter-spacing:-0.02em;margin-bottom:10px">
          Meet the <span class="green-text">Team</span>
        </h2>
        <p style="color:#8a8a8a;font-size:0.95rem;font-weight:500">The people behind your travel experience.</p>
      </div>

      <!-- ── FOUNDER (1 card, centered) ── -->
      <div style="margin-bottom:48px">
        <div style="text-align:center;margin-bottom:20px">
          <span style="display:inline-block;background:linear-gradient(135deg,rgba(52,224,161,0.12),rgba(0,170,108,0.08));border:1.5px solid rgba(0,170,108,0.25);border-radius:100px;padding:5px 18px;font-size:0.72rem;font-weight:800;color:#00AA6C;letter-spacing:0.06em;text-transform:uppercase">👑 Founder & Lead Developer</span>
        </div>
        <div style="max-width:320px;margin:0 auto">
          <div class="team-card">
            <div style="width:110px;height:110px;border-radius:50%;margin:0 auto 16px;overflow:hidden;border:3px solid #34E0A1;box-shadow:0 6px 24px rgba(0,170,108,0.25)">
              <img src="/images/team/IMG_20260425_154842.jpg.jpeg" alt="Yash Kumar" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#34E0A1,#00AA6C);display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:white;font-weight:900\'>Y</div>'">
            </div>
            <h3 style="font-size:1.15rem;font-weight:900;color:#1a1a1a;margin-bottom:4px">Yash Kumar</h3>
            <p style="font-size:0.8rem;color:#00AA6C;font-weight:700;margin-bottom:10px">Founder & Developer</p>
            <p style="color:#8a8a8a;font-size:0.82rem;line-height:1.7;font-weight:500">Full-stack developer passionate about building meaningful travel technology and connecting cultures.</p>
          </div>
        </div>
      </div>

      <!-- ── WEBSITE TEAM (3 cards) ── -->
      <div style="margin-bottom:48px">
        <div style="text-align:center;margin-bottom:20px">
          <span style="display:inline-block;background:linear-gradient(135deg,rgba(102,126,234,0.12),rgba(118,75,162,0.08));border:1.5px solid rgba(102,126,234,0.25);border-radius:100px;padding:5px 18px;font-size:0.72rem;font-weight:800;color:#667eea;letter-spacing:0.06em;text-transform:uppercase">🎨 Website Team</span>
        </div>
        <div class="grid md:grid-cols-3 gap-7">
          <div class="team-card">
            <div style="width:90px;height:90px;border-radius:50%;margin:0 auto 16px;overflow:hidden;border:3px solid #667eea;box-shadow:0 4px 16px rgba(102,126,234,0.25)">
              <img src="/images/team/IMG-20260323-WA0043.jpg.jpeg" alt="Web Team Member 1" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:white;font-weight:900\'>W1</div>'">
            </div>
            <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:4px">Member Name</h3>
            <p style="font-size:0.78rem;color:#667eea;font-weight:700;margin-bottom:10px">Frontend Developer</p>
            <p style="color:#8a8a8a;font-size:0.82rem;line-height:1.7;font-weight:500">Building responsive, beautiful interfaces for seamless travel discovery.</p>
          </div>
          <div class="team-card">
            <div style="width:90px;height:90px;border-radius:50%;margin:0 auto 16px;overflow:hidden;border:3px solid #667eea;box-shadow:0 4px 16px rgba(102,126,234,0.25)">
              <img src="/images/team/WhatsApp%20Image%202026-04-25%20at%2016.08.59.jpeg" alt="Web Team Member 2" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:white;font-weight:900\'>W2</div>'">
            </div>
            <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:4px">Member Name</h3>
            <p style="font-size:0.78rem;color:#667eea;font-weight:700;margin-bottom:10px">Backend Developer</p>
            <p style="color:#8a8a8a;font-size:0.82rem;line-height:1.7;font-weight:500">Architecting robust server-side systems and database management.</p>
          </div>
          <div class="team-card">
            <div style="width:90px;height:90px;border-radius:50%;margin:0 auto 16px;overflow:hidden;border:3px solid #667eea;box-shadow:0 4px 16px rgba(102,126,234,0.25)">
              <img src="/images/team/web3.jpg" alt="Web Team Member 3" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:white;font-weight:900\'>W3</div>'">
            </div>
            <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:4px">Member Name</h3>
            <p style="font-size:0.78rem;color:#667eea;font-weight:700;margin-bottom:10px">UI/UX Designer</p>
            <p style="color:#8a8a8a;font-size:0.82rem;line-height:1.7;font-weight:500">Crafting intuitive user experiences that make exploring feel effortless.</p>
          </div>
        </div>
      </div>

      <!-- ── DATA MANAGEMENT TEAM (3 cards) ── -->
      <div style="margin-bottom:48px">
        <div style="text-align:center;margin-bottom:20px">
          <span style="display:inline-block;background:linear-gradient(135deg,rgba(245,87,108,0.12),rgba(240,147,251,0.08));border:1.5px solid rgba(245,87,108,0.25);border-radius:100px;padding:5px 18px;font-size:0.72rem;font-weight:800;color:#f5576c;letter-spacing:0.06em;text-transform:uppercase">📊 Data Management Team</span>
        </div>
        <div class="grid md:grid-cols-3 gap-7">
          <div class="team-card">
            <div style="width:90px;height:90px;border-radius:50%;margin:0 auto 16px;overflow:hidden;border:3px solid #f5576c;box-shadow:0 4px 16px rgba(245,87,108,0.25)">
              <img src="/images/team/data1.jpg" alt="Data Team Member 1" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#f093fb,#f5576c);display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:white;font-weight:900\'>D1</div>'">
            </div>
            <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:4px">Member Name</h3>
            <p style="font-size:0.78rem;color:#f5576c;font-weight:700;margin-bottom:10px">Data Analyst</p>
            <p style="color:#8a8a8a;font-size:0.82rem;line-height:1.7;font-weight:500">Curating and verifying destination data for accurate travel insights.</p>
          </div>
          <div class="team-card">
            <div style="width:90px;height:90px;border-radius:50%;margin:0 auto 16px;overflow:hidden;border:3px solid #f5576c;box-shadow:0 4px 16px rgba(245,87,108,0.25)">
              <img src="/images/team/data2.jpg" alt="Data Team Member 2" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:linear-gradient(135deg,#f093fb,#f5576c);display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:white;font-weight:900\'>D2</div>'">
            </div>
            <h3 style="font-size:1.05rem;font-weight:800;color:#1a1a1a;margin-bottom:4px">Member Name</h3>
            <p style="font-size:0.78rem;color:#f5576c;font-weight:700;margin-bottom:10px">Database Engineer</p>
            <p style="color:#8a8a8a;font-size:0.82rem;line-height:1.7;font-weight:500">Managing databases and ensuring data integrity across the platform.</p>
          </div>
          <div class="team-card">
