<!-- views/partials/navbar.ejs -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-teal-600">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
        </svg>
        TripAdvisor
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
        <a href="/"            class="hover:text-teal-600 transition-colors">Home</a>
        <a href="/explore"     class="hover:text-teal-600 transition-colors">Explore</a>
        <a href="/experiences" class="hover:text-teal-600 transition-colors">Experiences</a>
        <a href="/reviews"     class="hover:text-teal-600 transition-colors">Reviews</a>
        <a href="/about"       class="hover:text-teal-600 transition-colors">About</a>
      </div>

      <!-- Right CTAs -->
      <div class="hidden md:flex items-center gap-3">
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <% if (typeof userRole !== 'undefined' && (userRole === 'host' || userRole === 'admin')) { %>
            <a href="/host/dashboard"
               class="text-sm text-teal-600 font-medium hover:text-teal-700 transition-colors">
              Dashboard
            </a>
          <% } else { %>
            <a href="/host/register"
               class="text-sm bg-teal-50 text-teal-700 border border-teal-200 px-4 py-2 rounded-full font-medium hover:bg-teal-100 transition-colors">
              Become a Host
            </a>
          <% } %>
          <a href="/profile"
             class="flex items-center gap-2 text-sm bg-teal-600 text-white px-4 py-2 rounded-full font-medium hover:bg-teal-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Profile
          </a>
        <% } else { %>
          <a href="/login"
             class="text-sm text-gray-600 font-medium hover:text-teal-600 transition-colors">
            Log In
          </a>
          <a href="/signup"
             class="text-sm bg-teal-600 text-white px-4 py-2 rounded-full font-medium hover:bg-teal-700 transition-colors">
            Sign Up
          </a>
        <% } %>
      </div>

      <!-- Mobile Hamburger -->
      <button id="menuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu" class="hidden md:hidden pb-4 border-t border-gray-100 mt-2 pt-4">
      <div class="flex flex-col gap-3 text-sm font-medium text-gray-600">
        <a href="/"            class="hover:text-teal-600">Home</a>
        <a href="/explore"     class="hover:text-teal-600">Explore</a>
        <a href="/experiences" class="hover:text-teal-600">Experiences</a>
        <a href="/reviews"     class="hover:text-teal-600">Reviews</a>
        <a href="/about"       class="hover:text-teal-600">About</a>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <a href="/host/register" class="text-teal-600 font-semibold">Become a Host</a>
          <a href="/profile"       class="text-teal-600 font-semibold">My Profile</a>
        <% } else { %>
          <a href="/login"  class="text-gray-700">Log In</a>
          <a href="/signup" class="text-teal-600 font-semibold">Sign Up</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<script>
  document.getElementById('menuBtn').addEventListener('click', () => {
    document.getElementById('mobileMenu').classList.toggle('hidden');
  });
</script>
