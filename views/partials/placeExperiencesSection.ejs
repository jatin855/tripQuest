     ADD THIS SECTION TO YOUR EXISTING PLACE PAGES
     e.g. paste into varanasi.ejs, jaisalmer.ejs, kedarkanth.ejs
     Change CITY_NAME to the actual city (e.g. "varanasi")
══════════════════════════════════════════════════════════════ -->

<!-- Local Experiences Section -->
<section class="py-16 max-w-7xl mx-auto px-4">
  <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-3">
    <div>
      <span class="text-teal-600 text-sm font-semibold uppercase tracking-wider">Community Hosted</span>
      <h2 class="text-3xl font-bold text-gray-900 mt-1">
        Local Experiences in <span id="cityDisplayName">this city</span>
      </h2>
      <p class="text-gray-500 text-sm mt-1">
        Authentic activities hosted by real locals — not tourist packages.
      </p>
    </div>
    <a id="viewAllLink" href="/experiences"
       class="text-teal-600 font-semibold text-sm hover:text-teal-700 whitespace-nowrap">
      View all experiences →
    </a>
  </div>

  <!-- Cards Container -->
  <div id="localExperiences" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Skeletons -->
    <div class="animate-pulse bg-gray-100 rounded-2xl h-64"></div>
    <div class="animate-pulse bg-gray-100 rounded-2xl h-64 hidden sm:block"></div>
    <div class="animate-pulse bg-gray-100 rounded-2xl h-64 hidden lg:block"></div>
  </div>
</section>

<!--
  HOW TO USE:
  1. Paste the HTML above into your place page (varanasi.ejs etc.)
  2. Add this <script> block at the bottom of that page
  3. Change "varanasi" below to the city matching that page
-->

<script>
  (function() {
    // ← CHANGE THIS to the city for this page
    const CITY = "varanasi";

    document.getElementById('cityDisplayName').textContent =
      CITY.charAt(0).toUpperCase() + CITY.slice(1);

    document.getElementById('viewAllLink').href =
      `/experiences?city=${CITY}`;

    fetch(`/experiences/city/${CITY}`)
      .then(r => r.json())
      .then(data => {
        const container = document.getElementById('localExperiences');

        if (!data.experiences || data.experiences.length === 0) {
          container.innerHTML = `
            <div class="col-span-3 bg-teal-50 border border-teal-100 rounded-2xl p-10 text-center">
              <div class="text-4xl mb-3">🎭</div>
              <p class="text-gray-600 font-medium mb-2">No experiences listed yet in ${CITY.charAt(0).toUpperCase() + CITY.slice(1)}</p>
              <a href="/host/register" class="text-teal-600 font-semibold text-sm hover:underline">
                Be the first host in this city →
              </a>
            </div>`;
          return;
        }

        container.innerHTML = data.experiences.map(exp => `
          <a href="/experiences/${exp.slug}"
             class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100 transition-all duration-300 flex flex-col">

            <div class="relative overflow-hidden h-44">
              ${exp.images && exp.images.length > 0
                ? `<img src="${exp.images[0]}" alt="${exp.title}"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>`
                : `<div class="w-full h-full bg-gradient-to-br from-teal-400 to-emerald-600 flex items-center justify-center text-4xl">🎭</div>`
              }
              <span class="absolute top-3 left-3 bg-white/90 text-teal-700 text-xs font-semibold px-3 py-1 rounded-full">
                ${exp.category}
              </span>
              <span class="absolute top-3 right-3 ${exp.isFree ? 'bg-green-500' : 'bg-teal-600'} text-white text-xs font-bold px-3 py-1 rounded-full">
                ${exp.isFree ? 'FREE' : '₹' + exp.price}
              </span>
            </div>

            <div class="p-4 flex flex-col flex-1">
              <h3 class="font-semibold text-gray-900 text-sm mb-1 group-hover:text-teal-600 transition-colors
                         overflow-hidden" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                ${exp.title}
              </h3>
              <div class="flex items-center gap-2 mt-auto pt-3 border-t border-gray-50">
                <div class="w-5 h-5 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 text-xs font-bold">
                  ${exp.hostName ? exp.hostName[0].toUpperCase() : 'H'}
                </div>
                <span class="text-xs text-gray-500">by <strong>${exp.hostName}</strong></span>
                ${exp.date ? `<span class="ml-auto text-xs text-gray-400">
                  ${new Date(exp.date).toLocaleDateString('en-IN',{day:'numeric',month:'short'})}
                </span>` : ''}
              </div>
            </div>
          </a>`
        ).join('');
      })
      .catch(() => {
        document.getElementById('localExperiences').innerHTML =
          `<p class="col-span-3 text-center text-gray-400 py-8">Could not load experiences.</p>`;
      });
  })();
</script>
