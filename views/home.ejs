<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TripQuest – Discover the World</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet" />
  <style>
    body {
      font-family: 'Nunito', sans-serif;
      background: #f7f8fa;
      color: #1a1a1a;
      overflow-x: hidden;
    }

    .dot-bg {
      position: fixed;
      inset: 0;
      z-index: -1;
      background-color: #f0f2f5;
      background-image: radial-gradient(circle, #c8cdd6 1px, transparent 1px);
      background-size: 24px 24px;
    }

    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.07);
      box-shadow: 0 1px 12px rgba(0, 0, 0, 0.06);
      transition: all 0.3s;
    }

    .green-text {
      background: linear-gradient(135deg, #00AA6C 0%, #34E0A1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-section {
      background: linear-gradient(160deg, #ffffff 0%, #f0fdf8 50%, #e6fdf5 100%);
      border-bottom: 1px solid rgba(52, 224, 161, 0.15);
    }

    .search-wrap {
      background: white;
      border: 1.5px solid #d4d4d4;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
      transition: all 0.2s;
    }

    .search-wrap:focus-within {
      border-color: #00AA6C;
      box-shadow: 0 4px 24px rgba(0, 170, 108, 0.15);
    }

    .search-input {
      outline: none;
      background: transparent;
    }

    .feature-card {
      background: white;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      border-radius: 16px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .feature-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 32px rgba(0, 170, 108, 0.12);
      border-color: rgba(0, 170, 108, 0.25);
    }

    .dest-card {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      position: relative;
    }

    .dest-card:hover {
      transform: translateY(-10px) scale(1.02);
      box-shadow: 0 20px 48px rgba(0, 170, 108, 0.15);
      border-color: rgba(0, 170, 108, 0.3);
    }

    .dest-card img {
      height: 220px;
      width: 100%;
      object-fit: cover;
      transition: 0.4s;
    }

    .dest-card:hover img {
      transform: scale(1.07);
    }

    .dest-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.75), transparent);
      padding: 1.5rem;
      opacity: 0;
      transform: translateY(12px);
      transition: 0.35s;
    }

    .dest-card:hover .dest-overlay {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── EXPERIENCE CARD ── */
    .exp-card {
      background: white;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      cursor: pointer;
    }

    .exp-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 16px 40px rgba(0, 170, 108, 0.14);
      border-color: rgba(0, 170, 108, 0.28);
    }

    .exp-card img {
      height: 190px;
      width: 100%;
      object-fit: cover;
      transition: 0.4s;
    }

    .exp-card:hover img {
      transform: scale(1.06);
    }

    .exp-tag {
      display: inline-block;
      background: rgba(52, 224, 161, 0.13);
      color: #00AA6C;
      border: 1px solid rgba(0, 170, 108, 0.2);
      border-radius: 100px;
      padding: 3px 12px;
      font-size: 0.72rem;
      font-weight: 700;
    }

    .stat-card {
      background: white;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      border-radius: 14px;
      padding: 1.75rem 1.5rem;
      text-align: center;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      transition: all 0.25s;
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 170, 108, 0.12);
    }

    .badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: linear-gradient(135deg, #00AA6C, #34E0A1);
      color: white;
      padding: 5px 14px;
      border-radius: 100px;
      font-size: 0.72rem;
      font-weight: 700;
      box-shadow: 0 4px 12px rgba(0, 170, 108, 0.35);
      z-index: 10;
    }

    .btn-green {
      background: #34E0A1;
      color: #1a1a1a;
      font-weight: 800;
      font-family: 'Nunito', sans-serif;
      border-radius: 10px;
      transition: all 0.22s;
      box-shadow: 0 4px 14px rgba(52, 224, 161, 0.38);
      border: none;
      cursor: pointer;
    }

    .btn-green:hover {
      background: #28d494;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(52, 224, 161, 0.48);
    }

    /* ── NAV LINK ACTIVE ── */
    .nav-link {
      color: #4a4a4a;
      cursor: pointer;
      transition: color 0.2s;
      position: relative;
    }

    .nav-link:hover {
      color: #00AA6C;
    }

    .nav-link.active {
      color: #00AA6C;
    }

    .nav-link.active::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, #00AA6C, #34E0A1);
      border-radius: 2px;
    }

    /* ── PROFILE AVATAR ── */
    .avatar {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, #34E0A1, #00AA6C);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 0.95rem;
      color: white;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(0, 170, 108, 0.35);
      flex-shrink: 0;
    }

    .avatar:hover {
      transform: scale(1.08);
      box-shadow: 0 4px 14px rgba(0, 170, 108, 0.45);
    }

    /* ── GREETING PILL ── */
    .greeting-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(52, 224, 161, 0.1);
      border: 1.5px solid rgba(0, 170, 108, 0.2);
      border-radius: 100px;
      padding: 5px 14px;
      font-size: 0.83rem;
      font-weight: 700;
      color: #00AA6C;
    }

    /* ── PROFILE BUTTON ── */
    .btn-profile {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: white;
      border: 1.5px solid rgba(0, 170, 108, 0.35);
      color: #00AA6C;
      font-weight: 800;
      font-family: 'Nunito', sans-serif;
      font-size: 0.83rem;
      border-radius: 10px;
      padding: 7px 16px;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.22s;
      box-shadow: 0 2px 8px rgba(0, 170, 108, 0.1);
    }

    .btn-profile:hover {
      background: rgba(0, 170, 108, 0.07);
      border-color: #00AA6C;
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(0, 170, 108, 0.18);
    }

    /* ── LOGOUT LINK ── */
    .btn-logout {
      font-size: 0.82rem;
      font-weight: 700;
      color: #8a8a8a;
      text-decoration: none;
      padding: 6px 14px;
      border: 1.5px solid #d4d4d4;
      border-radius: 8px;
      transition: all 0.2s;
      font-family: 'Nunito', sans-serif;
      background: transparent;
      cursor: pointer;
    }

    .btn-logout:hover {
      border-color: #e05252;
      color: #e05252;
    }

    .pop-tag {
      padding: 6px 16px;
      border: 1.5px solid #d4d4d4;
      border-radius: 100px;
      font-size: 0.82rem;
      font-weight: 600;
      color: #4a4a4a;
      background: white;
      cursor: pointer;
      transition: all 0.2s;
    }

    .pop-tag:hover {
      border-color: #00AA6C;
      color: #00AA6C;
      background: rgba(0, 170, 108, 0.05);
    }

    .test-card {
      background: white;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      border-radius: 16px;
      padding: 1.75rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      transition: all 0.25s;
    }

    .test-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 28px rgba(0, 170, 108, 0.1);
      border-color: rgba(0, 170, 108, 0.2);
    }

    .icon-box {
      width: 54px;
      height: 54px;
      background: linear-gradient(135deg, rgba(52, 224, 161, 0.15), rgba(0, 170, 108, 0.1));
      border: 1.5px solid rgba(0, 170, 108, 0.2);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      transition: 0.25s;
      margin-bottom: 1rem;
    }

    .feature-card:hover .icon-box {
      transform: scale(1.1) rotate(4deg);
      border-color: rgba(0, 170, 108, 0.4);
    }

    .cta-section {
      background: linear-gradient(135deg, #00AA6C 0%, #34E0A1 100%);
    }

    /* ── HOST BANNER ── */
    .host-banner {
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
      border-radius: 20px;
      overflow: hidden;
      position: relative;
    }

    .host-banner::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 80% 50%, rgba(52, 224, 161, 0.15), transparent 60%);
    }

    footer {
      background: #1a1a1a;
      color: #9a9a9a;
    }

    #loader {
      position: fixed;
      inset: 0;
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.5s;
    }

    .loader-bar {
      width: 220px;
      height: 4px;
      background: #e8e8e8;
      border-radius: 10px;
      overflow: hidden;
      margin-top: 20px;
    }

    .loader-bar::after {
      content: '';
      display: block;
      width: 50%;
      height: 100%;
      background: linear-gradient(90deg, #34E0A1, #00AA6C, #34E0A1);
      animation: load 1.4s infinite;
    }

    @keyframes load {
      from {
        transform: translateX(-100%)
      }

      to {
        transform: translateX(200%)
      }
    }

    .floating-chat {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, #00AA6C, #34E0A1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 100;
      box-shadow: 0 8px 24px rgba(0, 170, 108, 0.45);
      animation: floatBtn 3s ease infinite;
      transition: 0.25s;
    }

    .floating-chat:hover {
      transform: scale(1.1);
    }

    @keyframes floatBtn {

      0%,
      100% {
        transform: translateY(0)
      }

      50% {
        transform: translateY(-8px)
      }
    }

    /* ── LIVE SEARCH DROPDOWN ── */
    .search-form-wrap {
      position: relative;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .live-search-dropdown {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: white;
      border: 1.5px solid rgba(0, 170, 108, 0.2);
      border-radius: 0 0 16px 16px;
      max-height: 360px;
      overflow-y: auto;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
      z-index: 50;
      display: none;
    }

    .live-search-dropdown.show {
      display: block;
    }

    .lsd-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      cursor: pointer;
      transition: background 0.15s;
      text-decoration: none;
      color: #1a1a1a;
    }

    .lsd-item:hover {
      background: rgba(0, 170, 108, 0.06);
    }

    .lsd-item-emoji {
      font-size: 1.3rem;
      flex-shrink: 0;
      width: 32px;
      text-align: center;
    }

    .lsd-item-info {
      flex: 1;
      min-width: 0;
    }

    .lsd-item-name {
      font-weight: 700;
      font-size: 0.88rem;
    }

    .lsd-item-meta {
      font-size: 0.73rem;
      color: #8a8a8a;
      font-weight: 500;
    }

    .lsd-item-type {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 3px 10px;
      border-radius: 100px;
      flex-shrink: 0;
    }

    .lsd-item-type.state {
      background: rgba(196, 154, 60, 0.12);
      color: #c49a3c;
    }

    .lsd-item-type.city {
      background: rgba(45, 138, 86, 0.12);
      color: #2d8a56;
    }

    .lsd-item-type.place {
      background: rgba(74, 93, 156, 0.12);
      color: #4a5d9c;
    }

    .lsd-empty {
      padding: 24px;
      text-align: center;
      color: #8a8a8a;
      font-size: 0.85rem;
    }

    .lsd-loading {
      padding: 20px;
      text-align: center;
      color: #00AA6C;
      font-size: 0.85rem;
    }

    /* ── DYNAMIC REVIEW CARDS ── */
    .review-scroll-track {
      display: flex;
      gap: 20px;
      overflow-x: auto;
      padding: 8px 4px 16px;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .review-scroll-track::-webkit-scrollbar {
      display: none;
    }

    .review-card {
      flex: 0 0 340px;
      background: white;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      border-radius: 16px;
      padding: 1.75rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
    }

    .review-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(0, 170, 108, 0.12);
      border-color: rgba(0, 170, 108, 0.25);
    }

    .review-card-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }

    .review-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      color: white;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .review-username {
      font-weight: 800;
      color: #1a1a1a;
      font-size: 0.9rem;
    }

    .review-location {
      font-size: 0.75rem;
      color: #8a8a8a;
      font-weight: 500;
    }

    .review-stars {
      color: #f5a623;
      margin-bottom: 10px;
      font-size: 0.85rem;
      letter-spacing: 1px;
    }

    .review-text {
      color: #4a4a4a;
      font-size: 0.84rem;
      line-height: 1.7;
      font-weight: 500;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .review-time {
      font-size: 0.7rem;
      color: #b0b0b0;
      margin-top: 12px;
      font-weight: 600;
    }

    .review-quote {
      position: absolute;
      top: 14px;
      right: 18px;
      font-size: 2.5rem;
      color: rgba(0, 170, 108, 0.1);
      font-family: Georgia, serif;
      line-height: 1;
    }

    .scroll-btn-wrap {
      display: flex;
      gap: 10px;
    }

    .scroll-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1.5px solid #d4d4d4;
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 1rem;
      color: #4a4a4a;
    }

    .scroll-btn:hover {
      border-color: #00AA6C;
      color: #00AA6C;
      background: rgba(0, 170, 108, 0.05);
    }

    .review-stats-pill {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      background: rgba(52, 224, 161, 0.08);
      border: 1.5px solid rgba(0, 170, 108, 0.18);
      border-radius: 100px;
      padding: 8px 22px;
      margin-bottom: 14px;
    }

    .review-stats-pill .rsp-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.82rem;
      font-weight: 700;
      color: #00AA6C;
    }

    .review-stats-pill .rsp-divider {
      width: 1px;
      height: 18px;
      background: rgba(0, 170, 108, 0.2);
    }
  </style>
</head>

<body>

  <!-- LOADER -->
  <div id="loader">
    <div style="text-align:center">
      <div
        style="font-size:2.2rem;font-weight:900;background:linear-gradient(135deg,#00AA6C,#34E0A1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
        🦉 TripQuest
      </div>
      <div class="loader-bar"></div>
    </div>
  </div>

  <!-- DOT BACKGROUND -->
  <div class="dot-bg"></div>

  <!-- ══════════ NAVBAR ══════════ -->
  <header class="navbar">
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

      <!-- Logo -->
      <a href="/home" class="flex items-center gap-2 no-underline">
        <div
          style="width:36px;height:36px;background:#34E0A1;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;box-shadow:0 2px 8px rgba(52,224,161,.35)">
          🦉</div>
        <span style="font-size:1.2rem;font-weight:900;color:#1a1a1a;letter-spacing:-0.02em">Trip<span
            style="color:#00AA6C">Advisor</span></span>
      </a>

      <!-- Nav links -->
      <ul class="hidden md:flex gap-7 text-sm list-none" style="font-weight:700">
        <li class="nav-link active" onclick="window.location.href='/home'">Home</li>
        <li class="nav-link" onclick="window.location.href='/explore'">Explore</li>
        <!-- ✅ NEW: Experiences nav link -->
        <li class="nav-link" onclick="window.location.href='/experiences'">Experiences</li>
        <!-- ✅ NEW: Marketplace nav link -->
        <li class="nav-link" onclick="window.location.href='/marketplace'">Marketplace</li>
        <li class="nav-link" onclick="window.location.href='/reviews'">Reviews</li>
        <li class="nav-link" onclick="window.location.href='/about'">About</li>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
          <li class="nav-link" onclick="window.location.href='/admin/marketplace'" style="color:#f59e0b">🛡️ Admin</li>
        <% } %>
      </ul>

      <!-- ══ RIGHT SIDE: Logged-in vs Logged-out ══ -->
      <div class="flex items-center gap-3">

        <% if (typeof user !=='undefined' && user) { %>

          <!-- ✅ LOGGED IN -->
          <span class="greeting-pill hidden md:inline-flex">
            👋 Hey, <%= user.name.split(' ')[0] %>!
        </span>

        <a href="/profile" class="avatar" title="Go to Profile">
          <%= user.name.charAt(0).toUpperCase() %>
        </a>

        <a href="/profile" class="btn-profile hidden md:inline-flex">
          👤 Profile
        </a>

        <!-- Show host dashboard link if user is a host -->
        <% if (typeof userRole !== ' undefined' && userRole==='host' ) { %>
              <a href="/host/dashboard" class="btn-profile hidden md:inline-flex"
                style="border-color:rgba(52,224,161,0.5);color:#00AA6C">
                🏡 My Experiences
              </a>
              <% } %>

                <a href="/logout" class="btn-logout">Logout</a>

                <% } else { %>

                  <!-- ❌ NOT LOGGED IN -->
                  <a href="/login" style="font-size:0.85rem;font-weight:800;color:#00AA6C;text-decoration:none">Sign
                    In</a>
                  <a href="/register">
                    <button class="btn-green px-5 py-2 text-sm">Get Started</button>
                  </a>

                  <% } %>

      </div>
    </nav>
  </header>


  <!-- ══════════ HERO ══════════ -->
  <section class="hero-section py-24 px-6 text-center">
    <div class="max-w-4xl mx-auto">

      <% if (typeof user !=='undefined' && user) { %>
        <div
          style="display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,rgba(52,224,161,0.15),rgba(0,170,108,0.08));border:1.5px solid rgba(0,170,108,0.25);border-radius:100px;padding:8px 22px;font-size:0.88rem;font-weight:800;color:#00AA6C;margin-bottom:28px;box-shadow:0 2px 12px rgba(0,170,108,0.12)">
          🌍 Welcome back, <span style="color:#1a1a1a;margin-left:3px">
            <%=
              user.name.split(' ')[0] %></span>! Ready to explore?
    </div>
    <% } %>

