  <!-- ══════════ DYNAMIC REVIEWS ══════════ -->
  <section style="background:#f7f8fa;padding:80px 24px">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2
          style="font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:#1a1a1a;letter-spacing:-0.02em;margin-bottom:10px">
          What <span class="green-text">Travelers Say</span>
        </h2>
        <p style="color:#8a8a8a;font-size:0.95rem;font-weight:500;max-width:480px;margin:0 auto 18px">Real reviews from
          our community — powered by your experiences</p>

        <% if (typeof reviewStats !=='undefined' && reviewStats.totalReviews> 0) { %>
          <div class="review-stats-pill">
            <div class="rsp-item">⭐ <%= reviewStats.avgRating %> avg</div>
            <div class="rsp-divider"></div>
            <div class="rsp-item">📝 <%= reviewStats.totalReviews %> reviews</div>
          </div>
          <% } %>
      </div>

      <% if (typeof latestReviews !=='undefined' && latestReviews.length> 0) { %>
        <!-- Scroll controls -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <div style="font-size:0.82rem;font-weight:700;color:#8a8a8a">Showing latest <%= latestReviews.length %>
              reviews</div>
          <div class="scroll-btn-wrap">
            <button class="scroll-btn"
              onclick="document.getElementById('reviewTrack').scrollBy({left:-370,behavior:'smooth'})">←</button>
            <button class="scroll-btn"
              onclick="document.getElementById('reviewTrack').scrollBy({left:370,behavior:'smooth'})">→</button>
          </div>
        </div>

        <!-- Scrollable review cards -->
        <div class="review-scroll-track" id="reviewTrack">
          <% const avatarGradients=[ 'linear-gradient(135deg,#34E0A1,#00AA6C)'
            , 'linear-gradient(135deg,#667eea,#764ba2)' , 'linear-gradient(135deg,#f093fb,#f5576c)'
            , 'linear-gradient(135deg,#4facfe,#00f2fe)' , 'linear-gradient(135deg,#fa709a,#fee140)'
            , 'linear-gradient(135deg,#a18cd1,#fbc2eb)' , 'linear-gradient(135deg,#ffecd2,#fcb69f)'
            , 'linear-gradient(135deg,#89f7fe,#66a6ff)' , 'linear-gradient(135deg,#fddb92,#d1fdff)' ]; function
            timeAgo(dateStr) { var now=new Date(); var date=new Date(dateStr); var diff=Math.floor((now - date) / 1000);
            if (diff < 60) return 'just now' ; if (diff < 3600) return Math.floor(diff / 60) + 'm ago' ; if (diff <
            86400) return Math.floor(diff / 3600) + 'h ago' ; if (diff < 2592000) return Math.floor(diff / 86400)
            + 'd ago' ; if (diff < 31536000) return Math.floor(diff / 2592000) + 'mo ago' ; return Math.floor(diff /
            31536000) + 'y ago' ; } %>
            <% latestReviews.forEach(function(rev, idx) { %>
              <div class="review-card">
                <div class="review-quote">&ldquo;</div>
                <div class="review-card-header">
                  <div class="review-avatar" style="background:<%= avatarGradients[idx % avatarGradients.length] %>">
                    <%= rev.username ? rev.username.charAt(0).toUpperCase() : 'A' %>
                  </div>
                  <div>
                    <div class="review-username">
                      <%= rev.username || 'Anonymous' %>
                    </div>
                    <div class="review-location">📍 <%= rev.city %>, <%= rev.state %>
                    </div>
                  </div>
                </div>
                <div class="review-stars">
                  <% for(var i=0; i < rev.rating; i++) { %>⭐<% } %>
                      <% for(var i=rev.rating; i < 5; i++) { %>☆<% } %>
                </div>
                <p class="review-text">"<%= rev.reviewText %>"</p>
                <div class="review-time">
                  <%= timeAgo(rev.createdAt) %>
                </div>
              </div>
              <% }) %>
        </div>

        <!-- View all CTA -->
        <div style="text-align:center;margin-top:32px">
          <a href="/reviews" style="text-decoration:none">
            <button class="btn-green px-8 py-3" style="font-size:0.9rem">View All Reviews →</button>
          </a>
        </div>

        <% } else { %>
          <!-- No reviews fallback -->
          <div
            style="text-align:center;padding:48px 24px;background:white;border-radius:16px;border:1.5px dashed #d4d4d4">
            <div style="font-size:3rem;margin-bottom:12px">💬</div>
            <p style="font-size:1rem;font-weight:700;color:#4a4a4a;margin-bottom:6px">No reviews yet</p>
            <p style="font-size:0.85rem;color:#8a8a8a;font-weight:500">Be the first to share your travel experience!</p>
            <a href="/reviews" style="display:inline-block;margin-top:16px;text-decoration:none">
              <button class="btn-green px-6 py-2 text-sm">Write a Review →</button>
            </a>
          </div>
          <% } %>
    </div>
  </section>


  <!-- ══════════ CTA ══════════ -->
