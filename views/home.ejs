      <script>
        // ══════════════════════════════════════════
        //  TripQuest × CultureQuest Chat Widget
        //  Connects Node.js website → /api/chat
        //  which proxies to Flask on :5000
        // ══════════════════════════════════════════

        const CHAT_ENDPOINT = "/api/chat";   // Node proxy route (no CORS issues)
        let chatHistory = [];            // [{role, content}] keeps context
        let isOpen = false;
        let isWaiting = false;

        // ── DOM refs ──
        const panel = document.getElementById("chat-panel");
        const bubble = document.getElementById("chat-bubble");
        const msgBox = document.getElementById("chat-messages");
        const input = document.getElementById("chat-input");
        const sendBtn = document.getElementById("chat-send-btn");
        const charCount = document.getElementById("chat-char-count");

        // ── Auto-open if redirected from Plan Trip ──
        setTimeout(() => {
          if (localStorage.getItem('openChatbot') === '1') {
            localStorage.removeItem('openChatbot');
            if (!isOpen) toggleChat();
          }
        }, 800);

        // ── Toggle panel ──
        function toggleChat() {
          isOpen = !isOpen;
          panel.classList.toggle("open", isOpen);
          bubble.classList.toggle("open", isOpen);

          // Remove notif dot once opened
          const dot = bubble.querySelector(".notif-dot");
          if (isOpen && dot) dot.remove();

          if (isOpen) {
            // Show welcome only once
            if (msgBox.children.length === 0) showWelcome();
            setTimeout(() => input.focus(), 320);
          }
        }

        // ── Welcome message ──
        function showWelcome() {
          const userName = "<%= typeof user !== 'undefined' && user ? user.name.split(' ')[0] : 'Explorer' %>";
          appendBotMsg(`Hey ${userName}! 👋 I'm **TripBot**, your personal travel buddy.\n\nAsk me to plan a trip, find hidden gems, suggest itineraries, or anything travel-related! 🌍✈️`);
        }

        // ── Append bot message ──
        function appendBotMsg(text) {
          const now = new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
          const div = document.createElement("div");
          div.className = "msg bot";
          div.innerHTML = `
    <div class="msg-avatar">🦉</div>
    <div>
      <div class="msg-bubble">${formatText(text)}</div>
      <div class="msg-time">${now}</div>
    </div>`;
          msgBox.appendChild(div);
          scrollToBottom();
        }

        // ── Append user message ──
        function appendUserMsg(text) {
          const now = new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
          const initial = "<%= typeof user !== 'undefined' && user ? user.name.charAt(0).toUpperCase() : 'U' %>";
          const div = document.createElement("div");
          div.className = "msg user";
          div.innerHTML = `
    <div class="msg-avatar">${initial}</div>
    <div>
      <div class="msg-bubble">${escapeHtml(text)}</div>
      <div class="msg-time">${now}</div>
    </div>`;
          msgBox.appendChild(div);
          scrollToBottom();
        }

        // ── Typing indicator ──
        function showTyping() {
          const div = document.createElement("div");
          div.className = "msg bot";
          div.id = "typing-indicator";
          div.innerHTML = `
    <div class="msg-avatar">🦉</div>
    <div class="msg-bubble" style="padding:10px 16px">
      <div class="typing-indicator">
        <span></span><span></span><span></span>
      </div>
    </div>`;
          msgBox.appendChild(div);
          scrollToBottom();
        }
        function removeTyping() {
          const t = document.getElementById("typing-indicator");
          if (t) t.remove();
        }

        // ── Send message ──
        async function sendMessage() {
          const text = input.value.trim();
          if (!text || isWaiting) return;

          // Clear input
          input.value = "";
          charCount.textContent = "0 / 300";
          input.style.height = "auto";

          // Show user bubble
          appendUserMsg(text);

          // Add to history
          chatHistory.push({ role: "user", content: text });

          // Disable input
          isWaiting = true;
          sendBtn.disabled = true;
          showTyping();

          try {
            const res = await fetch(CHAT_ENDPOINT, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                message: text,
                history: chatHistory.slice(-8)   // last 8 turns for context
              })
            });

            if (!res.ok) throw new Error(`Server error: ${res.status}`);
            const data = await res.json();
            const reply = data.reply || data.response || data.message || "Sorry, I didn't get that.";

            removeTyping();
            appendBotMsg(reply);

            // Add bot reply to history
            chatHistory.push({ role: "assistant", content: reply });

            // Trim history to last 16 messages (8 turns)
            if (chatHistory.length > 16) chatHistory = chatHistory.slice(-16);

          } catch (err) {
            removeTyping();
            appendBotMsg(`Oops! Something went wrong 😅\n\nMake sure the AI server is running on port 5000.\n\n_Error: ${err.message}_`);
            console.error("[TripBot]", err);
          }

          isWaiting = false;
          sendBtn.disabled = false;
          input.focus();
        }

        // ── Quick suggestion chips ──
        function sendSuggestion(el) {
          const text = el.textContent.replace(/^[^\s]+\s/, "").trim(); // strip emoji
          input.value = text;
          sendMessage();
        }

        // ── Enter key to send (Shift+Enter for newline) ──
        function handleKey(e) {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
          }
        }

        // ── Auto-resize textarea ──
        function handleInputResize(el) {
          el.style.height = "auto";
          el.style.height = Math.min(el.scrollHeight, 100) + "px";
          charCount.textContent = `${el.value.length} / 300`;
        }

        // ── Helpers ──
        function scrollToBottom() {
          msgBox.scrollTop = msgBox.scrollHeight;
        }

        function escapeHtml(t) {
          return t.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }

        function formatText(t) {
          // bold **text**, italic _text_, line breaks
          return escapeHtml(t)
            .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
            .replace(/_(.*?)_/g, "<em>$1</em>")
            .replace(/\n/g, "<br>");
        }
      </script>


      <script>
        window.addEventListener('load', () => {
          const l = document.getElementById('loader');
          setTimeout(() => {
            l.style.opacity = '0';
            setTimeout(() => l.remove(), 500);
          }, 1400);
        });

        // ══════════ LIVE SEARCH ══════════
        (function () {
          const input = document.getElementById('heroSearchInput');
          const dropdown = document.getElementById('liveSearchDropdown');
          if (!input || !dropdown) return;

          let debounceTimer = null;

          input.addEventListener('input', function () {
            clearTimeout(debounceTimer);
            const q = this.value.trim();
            if (q.length < 2) { dropdown.classList.remove('show'); dropdown.innerHTML = ''; return; }

            dropdown.innerHTML = '<div class="lsd-loading">Searching...</div>';
            dropdown.classList.add('show');

            debounceTimer = setTimeout(async () => {
              try {
                const res = await fetch('/api/search?q=' + encodeURIComponent(q));
                const data = await res.json();
                renderDropdown(data.results || []);
              } catch (e) {
                dropdown.innerHTML = '<div class="lsd-empty">Search failed. Try again.</div>';
              }
            }, 300);
          });

          function renderDropdown(results) {
            if (!results.length) {
              dropdown.innerHTML = '<div class="lsd-empty">No results found. Try a different search.</div>';
              return;
            }

            let html = '';
            results.slice(0, 10).forEach(r => {
              let href = '#', typeClass = r.type || 'place', meta = '';
              if (r.type === 'state') {
                href = '/explore/' + r.stateId;
                meta = r.region || '';
              } else if (r.type === 'city') {
                href = '/city?state=' + r.stateId + '&id=' + r.cityId;
                meta = (r.stateName || '') + (r.tagline ? ' · ' + r.tagline : '');
              } else {
                href = '/city?state=' + r.stateId + '&id=' + r.cityId;
                meta = (r.category || '') + ' · ' + (r.cityName || '') + ', ' + (r.stateName || '');
              }

              html += '<a class="lsd-item" href="' + href + '">' +
                '<span class="lsd-item-emoji">' + (r.emoji || '📍') + '</span>' +
                '<div class="lsd-item-info">' +
                '<div class="lsd-item-name">' + escHtml(r.name) + '</div>' +
                '<div class="lsd-item-meta">' + escHtml(meta) + '</div>' +
                '</div>' +
                '<span class="lsd-item-type ' + typeClass + '">' + r.type + '</span>' +
                '</a>';
            });

            if (results.length > 10) {
              html += '<a class="lsd-item" href="/search?q=' + encodeURIComponent(input.value.trim()) + '" style="justify-content:center;color:#00AA6C;font-weight:700;font-size:0.85rem">' +
                'View all ' + results.length + ' results →</a>';
            }
            dropdown.innerHTML = html;
          }

          function escHtml(t) {
            const d = document.createElement('div'); d.textContent = t; return d.innerHTML;
          }

          // Close dropdown on outside click
          document.addEventListener('click', function (e) {
            if (!e.target.closest('.search-form-wrap')) { dropdown.classList.remove('show'); }
          });

          // Re-open on focus if value exists
          input.addEventListener('focus', function () {
            if (this.value.trim().length >= 2 && dropdown.innerHTML) dropdown.classList.add('show');
          });
        })();

        // ══════════ REVIEW AUTO-SCROLL ══════════
        (function () {
          const track = document.getElementById('reviewTrack');
          if (!track || !track.children.length) return;
          let scrollDir = 1;
          setInterval(() => {
            const maxScroll = track.scrollWidth - track.clientWidth;
            if (track.scrollLeft >= maxScroll - 5) scrollDir = -1;
            if (track.scrollLeft <= 5) scrollDir = 1;
            track.scrollBy({ left: scrollDir * 1, behavior: 'auto' });
          }, 30);
        })();
      </script>

  <!-- ══════════ CHATBOT INTEGRATION ══════════ -->
  <!-- Floating Action Button + Fullscreen Overlay -->
  <style>
    /* ── Chatbot FAB ── */
    .cq-fab {
      position: fixed;
      bottom: 32px;
      right: 32px;
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background: linear-gradient(135deg, #00AA6C 0%, #34E0A1 100%);
      border: none;
      cursor: pointer;
      z-index: 9998;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      color: white;
      box-shadow: 0 6px 28px rgba(0, 170, 108, 0.45), 0 0 0 0 rgba(52, 224, 161, 0.4);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      animation: cq-fab-pulse 2.5s infinite;
    }
    .cq-fab:hover {
      transform: scale(1.12) translateY(-2px);
      box-shadow: 0 10px 36px rgba(0, 170, 108, 0.55);
      animation: none;
    }
    .cq-fab:active { transform: scale(0.95); }
    @keyframes cq-fab-pulse {
      0%, 100% { box-shadow: 0 6px 28px rgba(0, 170, 108, 0.45), 0 0 0 0 rgba(52, 224, 161, 0.4); }
      50% { box-shadow: 0 6px 28px rgba(0, 170, 108, 0.45), 0 0 0 14px rgba(52, 224, 161, 0); }
    }

    /* Tooltip */
    .cq-fab-tooltip {
      position: absolute;
      right: 72px;
      top: 50%;
      transform: translateY(-50%);
      background: #1a1a1a;
      color: #fff;
      font-size: 0.78rem;
      font-weight: 700;
      padding: 8px 14px;
      border-radius: 10px;
      white-space: nowrap;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.25s;
      font-family: 'Nunito', sans-serif;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    }
    .cq-fab-tooltip::after {
      content: '';
      position: absolute;
      right: -6px;
      top: 50%;
      transform: translateY(-50%);
      border: 6px solid transparent;
      border-left-color: #1a1a1a;
    }
    .cq-fab:hover .cq-fab-tooltip { opacity: 1; }

    /* ── Fullscreen Overlay ── */
    .cq-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      align-items: stretch;
      justify-content: stretch;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.35s ease, visibility 0.35s ease;
    }
    .cq-overlay.open {
      opacity: 1;
      visibility: visible;
    }
    .cq-overlay iframe {
      width: 100%;
      height: 100%;
      border: none;
      background: #f5f0e8;
    }

    /* Close button */
    .cq-close-btn {
      position: fixed;
      top: 16px;
      right: 20px;
      z-index: 10001;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(26, 26, 26, 0.85);
      border: 2px solid rgba(255,255,255,0.15);
      color: #fff;
      font-size: 1.3rem;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      transition: all 0.25s;
      backdrop-filter: blur(8px);
      font-family: 'Nunito', sans-serif;
    }
    .cq-close-btn:hover {
      background: #ff4757;
      border-color: #ff4757;
      transform: rotate(90deg) scale(1.1);
    }
    .cq-overlay.open ~ .cq-close-btn { display: flex; }
    .cq-overlay.open ~ .cq-fab { display: none; }

    /* ── Loading state for iframe ── */
    .cq-loading {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      z-index: 10000;
      background: rgba(245, 240, 232, 0.95);
      transition: opacity 0.4s;
    }
    .cq-loading-spinner {
      width: 48px;
      height: 48px;
      border: 4px solid rgba(0, 170, 108, 0.15);
      border-top: 4px solid #00AA6C;
      border-radius: 50%;
      animation: cq-spin 0.9s linear infinite;
    }
    @keyframes cq-spin { to { transform: rotate(360deg); } }
    .cq-loading-text {
      font-size: 0.92rem;
      font-weight: 700;
      color: #1a2e1a;
      font-family: 'Nunito', sans-serif;
    }
    .cq-loading-sub {
      font-size: 0.78rem;
      color: #8a8a8a;
      font-family: 'Nunito', sans-serif;
    }
  </style>

  <!-- Floating Action Button -->
  <button class="cq-fab" id="cqFab" onclick="openChatbot()" aria-label="Open AI Travel Assistant">
    🌍
    <span class="cq-fab-tooltip">AI Travel Assistant</span>
  </button>

  <!-- Fullscreen Overlay -->
  <div class="cq-overlay" id="cqOverlay">
    <div class="cq-loading" id="cqLoading">
      <div class="cq-loading-spinner"></div>
      <div class="cq-loading-text">Loading CultureQuest AI...</div>
      <div class="cq-loading-sub">Your AI-powered travel companion</div>
    </div>
  </div>
  <button class="cq-close-btn" id="cqClose" onclick="closeChatbot()" aria-label="Close chatbot">✕</button>

  <script>
    // ── Chatbot overlay logic ──
    let cqIframeLoaded = false;

    function openChatbot() {
      const overlay = document.getElementById('cqOverlay');
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';

      // Lazy-load iframe on first open
      if (!cqIframeLoaded) {
        const iframe = document.createElement('iframe');
        iframe.src = 'http://localhost:5000';
        iframe.title = 'CultureQuest AI Travel Assistant';
        iframe.allow = 'microphone; clipboard-write';
        iframe.onload = function() {
          // Hide loading spinner once iframe is ready
          const loader = document.getElementById('cqLoading');
          if (loader) {
            loader.style.opacity = '0';
            setTimeout(() => loader.style.display = 'none', 400);
          }
        };
        overlay.appendChild(iframe);
        cqIframeLoaded = true;
      }
    }

    function closeChatbot() {
      const overlay = document.getElementById('cqOverlay');
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && document.getElementById('cqOverlay').classList.contains('open')) {
        closeChatbot();
      }
    });
  </script>
</body>

